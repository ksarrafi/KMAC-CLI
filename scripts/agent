#!/bin/bash
# agent — KmacAgent: persistent AI agent service for KMac-CLI
#
# Service:
#   kmac agent start                Start the daemon
#   kmac agent stop                 Stop the daemon
#   kmac agent restart              Restart the daemon
#   kmac agent status               Show daemon health
#
# Conversation:
#   kmac agent ask "question"       One-shot question (auto-starts daemon)
#   kmac agent chat                 Interactive session
#   kmac agent chat -s <session>    Resume a session
#   kmac agent chat -a devops       Talk to a specific agent
#
# Agents:
#   kmac agent agents               List all agent profiles
#   kmac agent create <name>        Create a new agent profile
#   kmac agent delete <name>        Delete an agent
#   kmac agent info [name]          Show agent details
#
# Sessions:
#   kmac agent sessions             List conversation sessions
#
# Memory:
#   kmac agent memory               List memories
#   kmac agent memory search "X"    Search agent memory
#   kmac agent remember "fact"      Teach the agent a fact
#   kmac agent forget <id>          Delete a memory
#
# Tasks:
#   kmac agent task "description"   Queue a background task
#   kmac agent task -p high "desc"  Queue with priority (low/normal/high/urgent)
#   kmac agent task --approve "d"   Queue with approval required
#   kmac agent tasks                List tasks with stats
#   kmac agent approve <id>         Approve a completed task
#   kmac agent reject <id>          Reject a completed task
#   kmac agent subtasks <id>        Show subtasks of a task
#
# Meta:
#   kmac agent logs                 Tail daemon log
#   kmac agent help                 Show this help

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_ui.sh"
source "$SCRIPT_DIR/_auth-helper.sh"

AGENT_HOME="${HOME}/.cache/kmac/agent"
AGENT_SOCK="${AGENT_HOME}/agent.sock"
AGENT_PID="${AGENT_HOME}/agent.pid"
AGENT_LOG="${AGENT_HOME}/agent.log"

# ─── Engine ──────────────────────────────────────────────────────────

_engine() {
    PYTHONPATH="$SCRIPT_DIR" python3 -m _agent_engine "$@"
}

_is_running() {
    [[ -S "$AGENT_SOCK" ]] || return 1
    _engine ping &>/dev/null 2>&1
}

_auto_start() {
    if ! _is_running; then
        ui_warn "Agent not running — starting daemon..."
        cmd_start || return 1
        sleep 1
    fi
}

# ─── Service Commands ────────────────────────────────────────────────

cmd_start() {
    if _is_running; then
        ui_info "Agent already running"
        return 0
    fi
    mkdir -p "$AGENT_HOME"
    _ensure_claude_auth || exit 1

    nohup env \
        PYTHONPATH="$SCRIPT_DIR" \
        ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" \
        python3 -m _agent_engine daemon \
        >> "$AGENT_LOG" 2>&1 &
    local pid=$!
    disown "$pid" 2>/dev/null

    local tries=0
    while (( tries < 20 )); do
        if [[ -S "$AGENT_SOCK" ]]; then
            ui_success "KmacAgent started (PID: $pid)"
            ui_dim "Socket: $AGENT_SOCK"
            return 0
        fi
        sleep 0.25
        ((tries++))
    done

    if kill -0 "$pid" 2>/dev/null; then
        ui_success "KmacAgent started (PID: $pid)"
    else
        ui_fail "Failed to start. Check: $AGENT_LOG"
        return 1
    fi
}

cmd_stop() {
    if [[ -f "$AGENT_PID" ]]; then
        local pid
        read -r pid < "$AGENT_PID"
        if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null
            local tries=0
            while (( tries < 20 )) && kill -0 "$pid" 2>/dev/null; do
                sleep 0.25; ((tries++))
            done
            ui_success "Agent stopped (PID: $pid)"
        else
            ui_warn "Agent not running (stale PID)"
            rm -f "$AGENT_PID" "$AGENT_SOCK"
        fi
    elif [[ -S "$AGENT_SOCK" ]]; then
        rm -f "$AGENT_SOCK"
        ui_warn "Removed stale socket"
    else
        ui_warn "Agent not running"
    fi
}

cmd_status() {
    title_box "KmacAgent" "🤖"
    if _is_running; then
        _engine status
    else
        echo -e "  Status:   ${DIM}○ Stopped${NC}"
        echo ""
        echo -e "  ${DIM}Start with:${NC} ${GREEN}kmac agent start${NC}"
    fi
    echo ""
}

# ─── Help ────────────────────────────────────────────────────────────

show_help() {
    cat <<'EOF'
Usage: kmac agent <command> [options]

Service:
  start                  Start the agent daemon
  stop                   Stop the daemon
  restart                Restart the daemon
  status                 Show daemon health + stats

Conversation:
  ask "question"         One-shot question with tool use
  chat                   Interactive session
    -a, --agent NAME     Agent profile to talk to (default: default)
    -s, --session ID     Resume a session
    -m, --model MODEL    Model override (opus, sonnet, haiku)

Agents:
  agents                 List all agent profiles
  create NAME            Create a new agent profile
    -m, --model MODEL    Model (default: sonnet)
    --system-prompt "X"  Custom system prompt
    --context "X"        Persistent context/rules
  update                 Update agent config
    -m, --model MODEL    Change model
    --system-prompt "X"  Change system prompt
    --context "X"        Change context
  delete NAME            Delete an agent
  info [NAME]            Show agent details

Sessions:
  sessions               List conversation sessions

Memory:
  memory                 List all memories
  memory search "query"  Search agent memory
  remember "fact"        Teach the agent something
  forget ID              Delete a memory

Tasks:
  task "description"     Queue a background task (auto-executed by daemon)
  task run ID            Immediately trigger a queued task
  task cancel ID         Cancel a running/queued task
  task result ID         Show task output
  tasks                  List all tasks

Schedules:
  schedule "desc" --cron "@hourly"   Create a recurring task
  schedule "desc" --cron "every 30m" Shorthand intervals
  schedules              List all schedules
  schedule delete ID     Remove a schedule

Sessions:
  sessions               List conversation sessions
  fork SESSION_ID        Fork/branch a session

Workflows:
  workflows              List available workflows
  workflow run <id>      Run a workflow (lint-fix, security-scan, etc)
  workflow <id>          Shorthand for workflow run

Skills:
  skills                 List loaded SKILL.md files

Profiles:
  profiles               List available tool profiles + groups

Maintenance:
  usage                  Show token usage by model
  prune                  Remove stale sessions (>14 days)
  export                 Export agent data to JSON
  import FILE            Import agent data from JSON
  plugins                List loaded plugins + MCP tools
  watches                List file watches

Meta:
  logs                   Tail the daemon log
  web                    Open web dashboard in browser
  help                   Show this help

Integration:
  Other KMAC tools can source _agent-hook.sh to call the agent:
    agent_ask "question"       One-shot question
    agent_diagnose "context"   Error diagnosis
    agent_remember "fact"      Save to memory
    agent_task "description"   Queue background task

Examples:
  kmac agent start && kmac agent ask "what's in this repo?"
  kmac agent chat -a devops -m opus
  kmac agent create reviewer -m sonnet --context "You do strict code reviews"
  kmac agent remember "We deploy to AWS us-east-1"
  kmac agent memory search "deploy"
  kmac agent task "scan all Dockerfiles for security issues"
  kmac agent task result abc123
EOF
}

# ─── Router ──────────────────────────────────────────────────────────

subcmd="${1:-chat}"
shift 2>/dev/null || true

case "$subcmd" in
    start)       cmd_start ;;
    stop)        cmd_stop ;;
    restart)     cmd_stop; sleep 1; cmd_start ;;
    status)      cmd_status ;;
    ask)         _auto_start && _engine ask "$@" ;;
    chat)        _auto_start && _engine chat "$@" ;;
    agents)      _auto_start && _engine agents-list "$@" ;;
    create)      _auto_start && _engine agent-create "$@" ;;
    delete)      _auto_start && _engine agent-delete "$@" ;;
    info)        _auto_start && _engine agent-info "$@" ;;
    sessions)    _auto_start && _engine sessions-list "$@" ;;
    memory)
        if [[ "${1:-}" == "search" ]]; then
            shift; _auto_start && _engine memory-search "$@"
        else
            _auto_start && _engine memory-list "$@"
        fi ;;
    remember)    _auto_start && _engine memory-add "$@" ;;
    forget)      _auto_start && _engine memory-delete --id "$@" ;;
    task)
        if [[ "${1:-}" == "cancel" ]]; then
            shift; _auto_start && _engine task-cancel "$@"
        elif [[ "${1:-}" == "run" ]]; then
            shift; _auto_start && _engine task-run "$@"
        elif [[ "${1:-}" == "result" || "${1:-}" == "show" ]]; then
            shift; _auto_start && _engine task-result "$@"
        else
            _auto_start && _engine task-create "$@"
        fi ;;
    tasks)       _auto_start && _engine tasks-list "$@" ;;
    approve)     _auto_start && _engine task-approve "$@" ;;
    reject)      _auto_start && _engine task-reject "$@" ;;
    subtasks)    _auto_start && _engine task-subtasks "$@" ;;
    update)      _auto_start && _engine agent-update "$@" ;;
    usage)       _auto_start && _engine token-usage "$@" ;;
    prune)       _auto_start && _engine prune "$@" ;;
    export)      _auto_start && _engine export "$@" ;;
    import)      _auto_start && _engine import "$@" ;;
    schedule)
        if [[ "${1:-}" == "delete" ]]; then
            shift; _auto_start && _engine schedule-delete "$@"
        elif [[ "${1:-}" == "list" ]]; then
            shift; _auto_start && _engine schedule-list "$@"
        else
            _auto_start && _engine schedule-create "$@"
        fi ;;
    schedules)   _auto_start && _engine schedule-list "$@" ;;
    fork)        _auto_start && _engine session-fork "$@" ;;
    plugins)     _auto_start && _engine plugins-list "$@" ;;
    watches)     _auto_start && _engine watches-list "$@" ;;
    workflows)   _auto_start && _engine workflows-list "$@" ;;
    workflow)
        if [[ "${1:-}" == "run" ]]; then
            shift; _auto_start && _engine workflow-run "$@"
        elif [[ "${1:-}" == "list" ]]; then
            shift; _auto_start && _engine workflows-list "$@"
        else
            _auto_start && _engine workflow-run "$@"
        fi ;;
    skills)      _auto_start && _engine skills-list "$@" ;;
    profiles)    _auto_start && _engine profiles-list "$@" ;;
    web)
        _auto_start
        local port
        port=$(_engine status 2>/dev/null | grep -oP 'web_port.*?(\d+)' | grep -oP '\d+' || echo "7890")
        if command -v open &>/dev/null; then
            open "http://127.0.0.1:${port:-7890}"
        else
            echo "  Open http://127.0.0.1:${port:-7890} in your browser"
        fi ;;
    logs)        tail -f "$AGENT_LOG" ;;
    -h|--help|help) show_help ;;
    *)
        _auto_start && _engine ask "$subcmd $*" ;;
esac

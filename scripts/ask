#!/bin/bash
# ask — instant Claude answer via API
# Usage: ask "how do I reverse a list in python"
#        echo "explain this" | ask
#        ask -m opus "hard question"
#        ask -i                        (interactive conversation)
#        git diff | ask "explain this"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_ui.sh"
source "$SCRIPT_DIR/_auth-helper.sh"

MODEL="claude-sonnet-4-6"
PROMPT=""
INTERACTIVE=false
CONTEXT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -m|--model) MODEL="$2"; shift 2 ;;
        -i|--interactive) INTERACTIVE=true; shift ;;
        -h|--help)
            echo "Usage: ask [-m model] [-i] \"question\""
            echo "       echo \"data\" | ask \"explain this\""
            echo "       ask -i  (interactive conversation)"
            echo ""
            echo "Models: sonnet (default), opus, haiku"
            exit 0 ;;
        *) PROMPT="$*"; break ;;
    esac
done

# Resolve model shortcuts
MODEL_LOWER=$(echo "$MODEL" | tr '[:upper:]' '[:lower:]')
case "$MODEL_LOWER" in
    opus)   MODEL="claude-opus-4-6" ;;
    haiku)  MODEL="claude-haiku-4-5" ;;
    sonnet) MODEL="claude-sonnet-4-6" ;;
esac

_ensure_claude_auth || exit 1

# Check for piped input (combine with prompt if both given)
if [[ ! -t 0 ]]; then
    PIPED=$(cat)
    if [[ -n "$PROMPT" ]]; then
        PROMPT="$PROMPT

Here is the relevant content:
\`\`\`
$PIPED
\`\`\`"
    else
        PROMPT="$PIPED"
    fi
fi

# Interactive conversation mode
if $INTERACTIVE; then
    title_box "Ask Claude" "🤖"
    echo -e "  ${BOLD}Model:${NC} ${CYAN}${MODEL}${NC}"
    echo -e "  ${DIM}Type 'exit' to quit, 'model X' to switch (opus/sonnet/haiku)${NC}"
    echo ""
    HISTORY=""
    while true; do
        read -r -p "  you> " input
        [[ "$input" == "exit" || "$input" == "quit" ]] && break
        if [[ "$input" == model\ * ]]; then
            MODEL="${input#model }"
            MODEL_LOWER=$(echo "$MODEL" | tr '[:upper:]' '[:lower:]')
            case "$MODEL_LOWER" in opus) MODEL="claude-opus-4-6";; haiku) MODEL="claude-haiku-4-5";; sonnet) MODEL="claude-sonnet-4-6";; esac
            ui_info "Switched to ${BOLD}$MODEL${NC}"
            continue
        fi
        [[ -z "$input" ]] && continue
        HISTORY="${HISTORY}User: ${input}\n"
        full_prompt="${HISTORY}Answer the user's latest question. Be concise."
        echo ""
        answer=$(_claude_ask "$full_prompt" "$MODEL" 4096 "Thinking")
        echo "$answer"
        HISTORY="${HISTORY}Assistant: ${answer}\n\n"
        echo ""
    done
    exit 0
fi

# Single-shot mode
if [[ -z "$PROMPT" ]]; then
    echo -e "  ${BOLD}Usage:${NC} ask \"your question\" or pipe input, or ${GREEN}ask -i${NC} for interactive"
    exit 1
fi

_claude_ask "$PROMPT" "$MODEL" 4096 "Thinking"

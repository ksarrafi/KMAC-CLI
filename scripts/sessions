#!/bin/bash
# sessions — Claude session manager
# Usage: sessions              (interactive picker)
#        sessions list          (list recent sessions)
#        sessions last          (resume most recent)
#        sessions search "term" (search sessions)

ACTION="${1:-picker}"
SEARCH_TERM="${2:-}"

case "$ACTION" in
    list|ls)
        echo "Recent Claude sessions:"
        echo ""
        # Show recent todo files as a proxy for sessions
        ls -lt ~/.claude/todos/ 2>/dev/null | head -20 | while read -r line; do
            echo "  $line"
        done
        echo ""
        echo "Use 'sessions resume <id>' to resume."
        ;;
    last|continue)
        exec claude --continue
        ;;
    search|find)
        if [[ -z "$SEARCH_TERM" ]]; then
            read -r -p "Search term: " SEARCH_TERM
        fi
        exec claude --resume "$SEARCH_TERM"
        ;;
    resume)
        if [[ -n "$2" ]]; then
            exec claude --resume "$2"
        else
            exec claude --resume
        fi
        ;;
    picker|*)
        exec claude --resume
        ;;
esac

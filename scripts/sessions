#!/bin/bash
# sessions — Claude session manager
# Usage: sessions              (interactive picker)
#        sessions list          (list recent sessions)
#        sessions last          (resume most recent)
#        sessions search "term" (search sessions)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_ui.sh"

ACTION="${1:-picker}"
SEARCH_TERM="${2:-}"

case "$ACTION" in
    list|ls)
        title_box "Claude Sessions"
        if [[ -d "$HOME/.claude/todos" ]]; then
            local_count=0
            find "$HOME/.claude/todos" -maxdepth 1 -type f -exec stat -f '%m	%N' {} \; 2>/dev/null \
                | sort -t'	' -rn | head -20 | cut -f2- \
                | while IFS= read -r line; do
                echo "  $line"
                ((local_count++)) || true
            done
            echo ""
            ui_dim "Use 'sessions resume <id>' to resume a session."
        else
            ui_dim "No sessions found."
        fi
        ;;
    last|continue)
        exec claude --continue
        ;;
    search|find)
        if [[ -z "$SEARCH_TERM" ]]; then
            echo ""
            read -r -p "  Search term: " SEARCH_TERM
        fi
        exec claude --resume "$SEARCH_TERM"
        ;;
    resume)
        if [[ -n "$2" ]]; then
            exec claude --resume "$2"
        else
            exec claude --resume
        fi
        ;;
    picker|*)
        exec claude --resume
        ;;
esac

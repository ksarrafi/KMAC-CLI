#!/bin/bash
# killport — find and kill processes on a port
# Usage: killport 3000
#        killport 3000 8080      (multiple)
#        killport --dry-run 3000 (show what would be killed)
#        killport                (list all listening)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_ui.sh"

DRY_RUN=false
PORTS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run|-d) DRY_RUN=true; shift ;;
        -h|--help)
            echo -e "  ${BOLD}Usage:${NC} killport [--dry-run] <port> [port2...]"
            echo -e "         killport  ${DIM}(list all listening ports)${NC}"
            exit 0 ;;
        *) PORTS+=("$1"); shift ;;
    esac
done

if [[ ${#PORTS[@]} -eq 0 ]]; then
    title_box "Listening Ports"
    printf "  ${BOLD}%-8s %-15s %-8s${NC}\n" "PORT" "PROCESS" "PID"
    echo -e "  ${DIM}$(printf '─%.0s' {1..35})${NC}"
    lsof -iTCP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {
        split($9,a,":")
        port=a[length(a)]
        if (!seen[port]++) {
            cmd=$1; pid=$2
            printf "  %-8s %-15s %-8s\n", port, cmd, pid
        }
    }' | sort -t' ' -k1 -n
    echo ""
    ui_dim "Use: killport <port> to kill a process"
    exit 0
fi

for PORT in "${PORTS[@]}"; do
    PIDS=$(lsof -ti :"$PORT" 2>/dev/null)
    if [[ -z "$PIDS" ]]; then
        ui_warn "No process on port ${BOLD}$PORT${NC}"
        continue
    fi

    for PID in $PIDS; do
        PNAME=$(ps -p "$PID" -o comm= 2>/dev/null)
        FULL_CMD=$(ps -p "$PID" -o args= 2>/dev/null)
        echo ""
        echo -e "  ${BOLD}Port:${NC}    $PORT"
        echo -e "  ${BOLD}Process:${NC} $PNAME ${DIM}(PID $PID)${NC}"
        echo -e "  ${BOLD}Command:${NC} ${DIM}$FULL_CMD${NC}"

        if $DRY_RUN; then
            ui_warn "[dry-run] Would kill PID $PID"
        else
            kill -9 "$PID" 2>/dev/null
            ui_success "Killed PID $PID"
        fi
    done
done
echo ""

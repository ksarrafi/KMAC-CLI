#!/bin/bash
# setup-mac — Bootstrap a new Mac with KMac-CLI and your personal config
# Usage:
#   On the new Mac, clone the repo and run:
#     git clone https://github.com/ksarrafi/KMAC-CLI.git ~/Projects/KMac-CLI
#     bash ~/Projects/KMac-CLI/scripts/setup-mac
#
# What it does:
#   1. Installs Homebrew (if missing)
#   2. Installs Oh My Zsh + plugins
#   3. Runs KMac install.sh (aliases, symlinks, deps)
#   4. Restores your dotfiles (.zshrc, .gitconfig, Claude config)
#   5. Restores Brewfile packages
#   6. Launches the vault guided setup for API keys

set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

ok()   { echo -e "  ${GREEN}✓${NC} $1"; }
warn() { echo -e "  ${YELLOW}!${NC} $1"; }
fail() { echo -e "  ${RED}✗${NC} $1"; }
info() { echo -e "  ${CYAN}>${NC} $1"; }
step() { echo ""; echo -e "${BOLD}${CYAN}[$1/$TOTAL_STEPS] $2${NC}"; }

TOTAL_STEPS=6

echo ""
echo -e "${BOLD}${CYAN}"
echo "  ╔══════════════════════════════════════╗"
echo "  ║      KMac-CLI · New Mac Setup        ║"
echo "  ╚══════════════════════════════════════╝"
echo -e "${NC}"
echo -e "  ${DIM}This will set up your terminal, tools, aliases,${NC}"
echo -e "  ${DIM}and secrets on this Mac.${NC}"
echo ""
printf "  Continue? [Y/n] "
read -r yn
[[ "$yn" =~ ^[nN] ]] && { echo "Aborted."; exit 0; }

# ─── Step 1: Homebrew ─────────────────────────────────────────────────────
step 1 "Homebrew"
if command -v brew &>/dev/null; then
    ok "Homebrew already installed"
else
    info "Homebrew not found — downloading installer for review..."
    _tmpsh=$(mktemp "${TMPDIR:-/tmp}/brew-install.XXXXXX")
    curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh -o "$_tmpsh" || { rm -f "$_tmpsh"; fail "Download failed"; exit 1; }
    info "Review installer: $_tmpsh"
    printf "  Install Homebrew? [y/N] "
    read -r yn
    if [[ "$yn" =~ ^[yY] ]]; then
        /bin/bash "$_tmpsh"
    fi
    rm -f "$_tmpsh"
    if ! command -v brew &>/dev/null; then
        fail "Homebrew not installed. Visit https://brew.sh"
        exit 1
    fi
    # Add brew to current session
    if [[ -f /opt/homebrew/bin/brew ]]; then
        export HOMEBREW_PREFIX="/opt/homebrew"
        export HOMEBREW_CELLAR="/opt/homebrew/Cellar"
        export HOMEBREW_REPOSITORY="/opt/homebrew"
        export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"
        export MANPATH="/opt/homebrew/share/man:${MANPATH:-}"
        export INFOPATH="/opt/homebrew/share/info:${INFOPATH:-}"
    fi
    ok "Homebrew installed"
fi

# ─── Step 2: Oh My Zsh + Plugins ──────────────────────────────────────────
step 2 "Oh My Zsh & Plugins"
if [[ -d "$HOME/.oh-my-zsh" ]]; then
    ok "Oh My Zsh already installed"
else
    info "Downloading Oh My Zsh installer..."
    _omzsh=$(mktemp "${TMPDIR:-/tmp}/ohmyzsh-install.XXXXXX")
    curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh -o "$_omzsh" || { rm -f "$_omzsh"; fail "Download failed"; exit 1; }
    info "Review installer: $_omzsh"
    printf "  Install Oh My Zsh? [y/N] "
    read -r yn
    if [[ "$yn" =~ ^[yY] ]]; then
        RUNZSH=no sh "$_omzsh" "" --unattended
    fi
    rm -f "$_omzsh"
    if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
        fail "Oh My Zsh not installed."
        exit 1
    fi
    ok "Oh My Zsh installed"
fi

ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

if [[ -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ]]; then
    ok "zsh-autosuggestions already installed"
else
    git clone https://github.com/zsh-users/zsh-autosuggestions "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
    ok "zsh-autosuggestions installed"
fi

if [[ -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ]]; then
    ok "zsh-syntax-highlighting already installed"
else
    git clone https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"
    ok "zsh-syntax-highlighting installed"
fi

# ─── Step 3: KMac-CLI Install ─────────────────────────────────────────────
step 3 "KMac-CLI (aliases, symlinks, deps)"
bash "$ROOT_DIR/install.sh"
ok "KMac-CLI installed"

# ─── Step 4: Restore Dotfiles ─────────────────────────────────────────────
step 4 "Restore Dotfiles"
if [[ -d "$ROOT_DIR/dotfiles" ]]; then
    info "Found dotfile backup. Restoring..."
    bash "$SCRIPT_DIR/dotbackup" restore
    ok "Dotfiles restored"
else
    warn "No dotfile backup found in repo."
    info "Run 'kmac dotbackup' on your current Mac to back up dotfiles."
fi

# ─── Step 5: Brewfile Packages ────────────────────────────────────────────
step 5 "Brew Packages"
if [[ -f "$ROOT_DIR/Brewfile" ]]; then
    echo ""
    echo -e "  ${DIM}Your Brewfile has these packages:${NC}"
    grep -E '^(brew|cask)' "$ROOT_DIR/Brewfile" | head -15 | sed 's/^/    /'
    local_count=$(grep -cE '^(brew|cask)' "$ROOT_DIR/Brewfile" 2>/dev/null || echo 0)
    (( local_count > 15 )) && echo -e "    ${DIM}... and $((local_count - 15)) more${NC}"
    echo ""
    printf "  Install all Brew packages? [y/N] "
    read -r yn
    if [[ "$yn" =~ ^[yY] ]]; then
        brew bundle --file="$ROOT_DIR/Brewfile"
        ok "Brew packages installed"
    else
        warn "Skipped Brew packages"
    fi
else
    warn "No Brewfile found. Run 'kmac dotbackup' on current Mac to export one."
fi

# ─── Step 6: Secrets / API Keys ──────────────────────────────────────────
step 6 "Secrets & API Keys"
echo ""
echo -e "  ${DIM}Your API keys are stored securely in the KMac vault.${NC}"
echo -e "  ${DIM}You'll need to re-enter them on this Mac (they don't sync for security).${NC}"
echo ""
printf "  Run guided API key setup now? [y/N] "
read -r yn
if [[ "$yn" =~ ^[yY] ]]; then
    bash "$SCRIPT_DIR/secrets"
else
    info "You can run 'kmac secrets' anytime to set up API keys."
fi

# ─── Done ─────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}  ╔══════════════════════════════════════╗"
echo "  ║       Setup Complete!                ║"
echo -e "  ╚══════════════════════════════════════╝${NC}"
echo ""
echo -e "  ${BOLD}Reload your shell:${NC}   source ~/.zshrc"
echo -e "  ${BOLD}Launch KMac:${NC}         kmac"
echo ""
echo -e "  ${DIM}Your terminal config, aliases, and tools are ready.${NC}"
echo ""

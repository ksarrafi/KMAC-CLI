#!/bin/bash
# paperclip — Manage the Paperclip AI orchestration platform
# Usage: paperclip start|stop|status|logs|open|doctor|help

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_ui.sh"

PAPERCLIP_DIR="${PAPERCLIP_DIR:-$HOME/Projects/PClips/paperclip}"
PAPERCLIP_PORT="${PAPERCLIP_PORT:-3100}"
PAPERCLIP_URL="http://127.0.0.1:${PAPERCLIP_PORT}"
CONFIG_DIR="$HOME/.config/kmac/paperclip"
PID_FILE="$CONFIG_DIR/server.pid"
LOG_FILE="$CONFIG_DIR/server.log"

_ensure_dirs() {
    mkdir -p "$CONFIG_DIR"
    chmod 700 "$CONFIG_DIR"
}

_check_prereqs() {
    if [[ ! -d "$PAPERCLIP_DIR" ]]; then
        ui_fail "Paperclip not found at $PAPERCLIP_DIR"
        echo "  Set PAPERCLIP_DIR to your paperclip repo path."
        return 1
    fi
    if ! command -v node &>/dev/null; then
        ui_fail "Node.js is required (>= 20)"
        return 1
    fi
    if ! command -v pnpm &>/dev/null; then
        ui_fail "pnpm is required"
        echo "  Install: npm install -g pnpm"
        return 1
    fi
}

_server_pid() {
    local pid=""
    [[ -f "$PID_FILE" ]] && read -r pid < "$PID_FILE" 2>/dev/null
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
        echo "$pid"
    fi
}

_health_check() {
    curl -sf --max-time 3 "${PAPERCLIP_URL}/api/health" 2>/dev/null
}

do_start() {
    _ensure_dirs
    _check_prereqs || return 1

    local pid; pid=$(_server_pid)
    if [[ -n "$pid" ]]; then
        ui_warn "Paperclip already running (PID $pid)"
        return 0
    fi

    if [[ ! -d "$PAPERCLIP_DIR/node_modules" ]]; then
        ui_info "Installing dependencies (first run)..."
        (cd "$PAPERCLIP_DIR" && pnpm install --frozen-lockfile) || {
            ui_fail "pnpm install failed"
            return 1
        }
    fi

    local mode="${1:-}"
    local dev_args=()
    [[ "$mode" == "--tailscale-auth" ]] && dev_args+=("--tailscale-auth")

    ui_info "Starting Paperclip server..."
    (cd "$PAPERCLIP_DIR" && nohup pnpm dev "${dev_args[@]}" >> "$LOG_FILE" 2>&1 &
     echo $! > "$PID_FILE")

    local attempts=0
    while (( attempts < 30 )); do
        if _health_check &>/dev/null; then
            local resp; resp=$(_health_check)
            local deploy_mode; deploy_mode=$(echo "$resp" | grep -o '"deploymentMode":"[^"]*"' | cut -d'"' -f4)
            ui_success "Paperclip started (PID $(cat "$PID_FILE"))"
            echo ""
            echo "  URL:   ${PAPERCLIP_URL}"
            echo "  Mode:  ${deploy_mode:-local_trusted}"
            echo "  Logs:  $LOG_FILE"
            echo ""
            return 0
        fi
        sleep 1
        ((attempts++))
    done

    ui_fail "Paperclip failed to start within 30s — check $LOG_FILE"
    return 1
}

do_stop() {
    local pid; pid=$(_server_pid)
    if [[ -z "$pid" ]]; then
        # Also try to find pnpm/node processes from paperclip
        local found_pid
        found_pid=$(pgrep -f "paperclip.*dev-runner" 2>/dev/null | head -1)
        if [[ -n "$found_pid" ]]; then
            pid="$found_pid"
        else
            ui_warn "Paperclip not running"
            rm -f "$PID_FILE"
            return 0
        fi
    fi

    ui_info "Stopping Paperclip (PID $pid)..."
    kill "$pid" 2>/dev/null
    # Also kill child node processes
    pkill -P "$pid" 2>/dev/null || true

    local i=0
    while (( i < 10 )) && kill -0 "$pid" 2>/dev/null; do
        sleep 0.5
        ((i++))
    done
    if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null
        pkill -9 -P "$pid" 2>/dev/null || true
    fi
    rm -f "$PID_FILE"
    ui_success "Paperclip stopped"
}

do_restart() {
    do_stop
    sleep 1
    do_start "$@"
}

do_status() {
    local pid; pid=$(_server_pid)
    if [[ -n "$pid" ]]; then
        ui_success "Paperclip running (PID $pid)"
        echo ""
        echo "  URL:    ${PAPERCLIP_URL}"
        echo "  PID:    $pid"
        echo "  Dir:    $PAPERCLIP_DIR"
        echo "  Log:    $LOG_FILE"
        echo ""
        local resp; resp=$(_health_check)
        if [[ -n "$resp" ]]; then
            local deploy_mode; deploy_mode=$(echo "$resp" | grep -o '"deploymentMode":"[^"]*"' | cut -d'"' -f4)
            local deploy_exp; deploy_exp=$(echo "$resp" | grep -o '"deploymentExposure":"[^"]*"' | cut -d'"' -f4)
            echo "  Health:   OK"
            echo "  Mode:     ${deploy_mode:-unknown}"
            echo "  Exposure: ${deploy_exp:-unknown}"
        else
            echo "  Health:   NOT RESPONDING"
        fi
    else
        ui_warn "Paperclip not running"
        rm -f "$PID_FILE"
        echo ""
        echo "  Dir:  $PAPERCLIP_DIR"
        [[ -d "$PAPERCLIP_DIR" ]] && echo "  Repo: found" || echo "  Repo: NOT FOUND"
    fi
}

do_logs() {
    local lines="${1:-50}"
    if [[ ! -f "$LOG_FILE" ]]; then
        ui_warn "No log file found at $LOG_FILE"
        return 1
    fi
    if [[ "${1:-}" == "-f" || "${1:-}" == "follow" ]]; then
        tail -f "$LOG_FILE"
    else
        tail -n "$lines" "$LOG_FILE"
    fi
}

do_open() {
    if _health_check &>/dev/null; then
        open "${PAPERCLIP_URL}" 2>/dev/null || xdg-open "${PAPERCLIP_URL}" 2>/dev/null
        ui_success "Opened ${PAPERCLIP_URL} in browser"
    else
        ui_warn "Paperclip not responding — start it first"
    fi
}

do_doctor() {
    title_box "Paperclip Doctor" "🏥"
    local issues=0

    echo -e "  ${BOLD}Prerequisites:${NC}"
    if [[ -d "$PAPERCLIP_DIR" ]]; then
        echo -e "    ${GREEN}✓${NC} Repo: $PAPERCLIP_DIR"
    else
        echo -e "    ${RED}✗${NC} Repo not found at $PAPERCLIP_DIR"
        ((issues++))
    fi

    for dep in node pnpm; do
        if command -v "$dep" &>/dev/null; then
            local ver; ver=$("$dep" --version 2>/dev/null | head -1)
            echo -e "    ${GREEN}✓${NC} $dep  ${DIM}${ver}${NC}"
        else
            echo -e "    ${RED}✗${NC} $dep not found"
            ((issues++))
        fi
    done

    if [[ -d "$PAPERCLIP_DIR/node_modules" ]]; then
        echo -e "    ${GREEN}✓${NC} Dependencies installed"
    else
        echo -e "    ${YELLOW}!${NC} Dependencies not installed ${DIM}(run: kmac paperclip start)${NC}"
    fi

    echo ""
    echo -e "  ${BOLD}Server:${NC}"
    local pid; pid=$(_server_pid)
    if [[ -n "$pid" ]]; then
        echo -e "    ${GREEN}✓${NC} Running (PID $pid)"
        if _health_check &>/dev/null; then
            echo -e "    ${GREEN}✓${NC} Health check passed"
        else
            echo -e "    ${RED}✗${NC} Health check failed"
            ((issues++))
        fi
    else
        echo -e "    ${DIM}○${NC} Not running"
    fi

    echo ""
    echo -e "  ${BOLD}Adapters:${NC}"
    if [[ -d "$PAPERCLIP_DIR/packages/adapters" ]]; then
        for adapter in "$PAPERCLIP_DIR/packages/adapters"/*/; do
            [[ -d "$adapter" ]] || continue
            local name; name=$(basename "$adapter")
            echo -e "    ${GREEN}✓${NC} $name"
        done
    fi

    echo ""
    (( issues == 0 )) && echo -e "  ${GREEN}${BOLD}All clear!${NC}" || echo -e "  ${YELLOW}${BOLD}$issues issue(s) found.${NC}"
}

do_interactive() {
    while true; do
        clear
        title_box "Paperclip — AI Agent Orchestration" "📎"

        local pid; pid=$(_server_pid)
        if [[ -n "$pid" ]]; then
            local health_ok=false
            _health_check &>/dev/null && health_ok=true
            if $health_ok; then
                echo -e "  Status: ${GREEN}● Running${NC}  ${DIM}(PID $pid)${NC}"
            else
                echo -e "  Status: ${YELLOW}● Running (unhealthy)${NC}  ${DIM}(PID $pid)${NC}"
            fi
            echo -e "  URL:    ${GREEN}${PAPERCLIP_URL}${NC}"
        else
            echo -e "  Status: ${DIM}○ Stopped${NC}"
        fi

        echo -e "  Path:   ${DIM}${PAPERCLIP_DIR}${NC}"
        echo ""
        echo -e "  ${GREEN}s${NC}) Start              ${GREEN}S${NC}) Stop"
        echo -e "  ${GREEN}r${NC}) Restart             ${GREEN}o${NC}) Open in Browser"
        echo -e "  ${GREEN}l${NC}) Logs ${DIM}(last 50)${NC}      ${GREEN}L${NC}) Logs ${DIM}(follow)${NC}"
        echo -e "  ${GREEN}d${NC}) Doctor              ${GREEN}c${NC}) OpenClaw Manager"
        echo ""
        echo -e "  ${DIM}m) Back${NC}"
        echo ""
        read -r -n1 -p "  > " ch; echo ""
        case "$ch" in
            s) do_start; read -r -n1 -p "  Press any key..."; echo "" ;;
            S) do_stop; read -r -n1 -p "  Press any key..."; echo "" ;;
            r) do_restart; read -r -n1 -p "  Press any key..."; echo "" ;;
            o) do_open ;;
            l) do_logs 50; read -r -n1 -p "  Press any key..."; echo "" ;;
            L) do_logs -f ;;
            d) do_doctor; read -r -n1 -p "  Press any key..."; echo "" ;;
            c) bash "$SCRIPT_DIR/openclaw" ;;
            m|M) return ;;
        esac
    done
}

do_help() {
    cat <<'HELP'
Paperclip — AI Agent Orchestration Platform

Usage: kmac paperclip <command>

Commands:
  start [--tailscale-auth]   Start the Paperclip server
  stop                       Stop the server
  restart                    Restart the server
  status                     Show server status + health
  logs [N|-f]                Show last N log lines (default 50), or follow
  open                       Open the UI in your browser
  doctor                     Check prerequisites and health

Environment:
  PAPERCLIP_DIR    Repo path (default: ~/Projects/PClips/paperclip)
  PAPERCLIP_PORT   Server port (default: 3100)
HELP
}

# ─── CLI Router ─────────────────────────────────────────────────────────────
case "${1:-}" in
    start)       shift; do_start "$@" ;;
    stop)        do_stop ;;
    restart)     shift; do_restart "$@" ;;
    status)      do_status ;;
    logs)        shift; do_logs "$@" ;;
    open)        do_open ;;
    doctor)      do_doctor ;;
    help|--help|-h) do_help ;;
    "")          do_interactive ;;
    *)           ui_fail "Unknown command: $1"; do_help; exit 1 ;;
esac

#!/bin/bash
# cursoragent — quick Cursor Agent task from the command line
# Usage: cursoragent "add error handling to server.js"
#        cursoragent   (interactive prompt)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_ui.sh"

PROMPT="$*"

if [[ -z "$PROMPT" ]]; then
    if [[ -t 0 ]]; then
        title_box "Cursor Agent"
        echo -e "  ${DIM}Run a task with Cursor's AI agent. Describe what you want in natural language.${NC}"
        echo ""
        read -r -p "  Task: " PROMPT
        echo ""
    else
        PROMPT=$(cat)
    fi
fi

if [[ -z "$PROMPT" ]]; then
    echo -e "  ${BOLD}Usage:${NC} cursoragent \"your task description\""
    exit 1
fi

if ! command -v cursor &>/dev/null; then
    ui_fail "cursor CLI not found"
    ui_dim "Install: https://cursor.com/download"
    exit 1
fi

exec cursor agent "$PROMPT"

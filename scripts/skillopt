#!/bin/bash
# skillopt — Karpathy-style skill optimizer for KMac Assistant
# Iteratively refines SKILL.md files using eval loops until they hit a target success rate.
# Uses Claude as both the test subject and the eval judge.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ASSISTANT_DIR="$TOOLKIT_DIR/assistant"
SKILLS_DIR="$HOME/.config/kmac/assistant/skills"

source "$SCRIPT_DIR/_ui.sh"
source "$SCRIPT_DIR/_vault.sh" 2>/dev/null

_ensure_anthropic_key() {
    if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
        if [[ -f "$SCRIPT_DIR/_vault.sh" ]]; then
            local key; key=$(vault_get "anthropic" 2>/dev/null)
            if [[ -n "$key" ]]; then
                export ANTHROPIC_API_KEY="$key"
                return 0
            fi
        fi
        ui_fail "ANTHROPIC_API_KEY is required"
        echo "  Set it with: kmac secrets set anthropic"
        return 1
    fi
}

_ensure_deps() {
    if [[ ! -d "$ASSISTANT_DIR/node_modules" ]]; then
        ui_info "Installing dependencies..."
        (cd "$ASSISTANT_DIR" && npm install --silent 2>&1) || {
            ui_fail "npm install failed"
            return 1
        }
    fi
}

_list_skills() {
    if [[ ! -d "$SKILLS_DIR" ]]; then
        echo ""
        return
    fi
    for d in "$SKILLS_DIR"/*/; do
        [[ -f "$d/SKILL.md" ]] && echo "$d"
    done
}

# ─── Commands ─────────────────────────────────────────────────────────

do_init() {
    local skill_dir="${1:-}"

    if [[ -z "$skill_dir" ]]; then
        echo ""
        echo -e "  ${BOLD}Create a new skill or generate eval for an existing one?${NC}"
        echo ""
        echo -e "  ${GREEN}n${NC}) New skill from scratch"
        echo -e "  ${GREEN}e${NC}) Generate eval.json for existing skill"
        echo -e "  ${GREEN}m${NC}) Back"
        echo ""
        read -r -n1 -p "  > " ch; echo ""

        case "$ch" in
            n|N)
                echo ""
                read -r -p "  Skill name: " skill_name
                [[ -z "$skill_name" ]] && return
                skill_dir="$SKILLS_DIR/$skill_name"
                mkdir -p "$skill_dir"

                echo ""
                echo -e "  ${BOLD}What should this skill do?${NC}"
                echo -e "  ${DIM}Describe the skill in a few sentences. Press Enter twice when done.${NC}"
                echo ""
                local desc="" line=""
                while IFS= read -r line; do
                    [[ -z "$line" ]] && break
                    desc+="$line"$'\n'
                done

                cat > "$skill_dir/SKILL.md" << SKILL_EOF
# ${skill_name}

${desc:-Describe what this skill does and how the AI should behave when it's active.}

## Instructions

- Follow these instructions when this skill is active
- Be specific about format, structure, and constraints
- Include examples of correct output

## Output Format

Describe the expected output format here.

## Examples

### Example 1
**User**: (example prompt)
**Assistant**: (example response)
SKILL_EOF

                ui_success "Created $skill_dir/SKILL.md"
                echo -e "  ${DIM}Edit it, then run:${NC} ${GREEN}kmac skillopt init $skill_dir${NC} ${DIM}to generate evals${NC}"
                return
                ;;
            e|E)
                echo ""
                local skills=()
                while IFS= read -r d; do
                    [[ -n "$d" ]] && skills+=("$d")
                done < <(_list_skills)

                if (( ${#skills[@]} == 0 )); then
                    ui_warn "No skills found in $SKILLS_DIR"
                    return
                fi

                echo -e "  ${BOLD}Select a skill:${NC}"
                echo ""
                local i=0
                for s in "${skills[@]}"; do
                    local name; name=$(basename "$s")
                    local has_eval=""
                    [[ -f "$s/eval.json" ]] && has_eval=" ${GREEN}(has eval.json)${NC}"
                    echo -e "  ${GREEN}$((i+1))${NC}) ${name}${has_eval}"
                    ((i++))
                done
                echo ""
                read -r -p "  > " pick
                [[ "$pick" =~ ^[0-9]+$ ]] || return
                ((pick--))
                (( pick >= 0 && pick < ${#skills[@]} )) || return
                skill_dir="${skills[$pick]}"
                ;;
            *) return ;;
        esac
    fi

    if [[ ! -f "$skill_dir/SKILL.md" ]]; then
        ui_fail "No SKILL.md in $skill_dir"
        return 1
    fi

    if [[ -f "$skill_dir/eval.json" ]]; then
        ui_warn "eval.json already exists"
        echo -e "  ${GREEN}o${NC}) Overwrite    ${GREEN}e${NC}) Edit    ${GREEN}m${NC}) Cancel"
        read -r -n1 -p "  > " ch; echo ""
        case "$ch" in
            o|O) ;;
            e|E) ${EDITOR:-vim} "$skill_dir/eval.json"; return ;;
            *) return ;;
        esac
    fi

    _ensure_anthropic_key || return 1
    _ensure_deps || return 1

    ui_info "Generating eval.json from SKILL.md..."
    (cd "$ASSISTANT_DIR" && ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" npx tsx src/optimizer.ts init "$skill_dir")

    if [[ -f "$skill_dir/eval.json" ]]; then
        ui_success "Created eval.json"
        echo ""
        echo -e "  ${DIM}Review and edit:${NC} ${GREEN}${EDITOR:-vim} $skill_dir/eval.json${NC}"
        echo -e "  ${DIM}Then optimize:${NC}  ${GREEN}kmac skillopt run $skill_dir${NC}"
    fi
}

do_run() {
    local skill_dir="${1:-}"
    shift 2>/dev/null

    if [[ -z "$skill_dir" ]]; then
        local skills=()
        while IFS= read -r d; do
            [[ -n "$d" && -f "$d/eval.json" ]] && skills+=("$d")
        done < <(_list_skills)

        if (( ${#skills[@]} == 0 )); then
            ui_warn "No skills with eval.json found"
            echo -e "  ${DIM}Run${NC} ${GREEN}kmac skillopt init${NC} ${DIM}to set up a skill for optimization.${NC}"
            return
        fi

        echo ""
        echo -e "  ${BOLD}Select a skill to optimize:${NC}"
        echo ""
        local i=0
        for s in "${skills[@]}"; do
            local name; name=$(basename "$s")
            echo -e "  ${GREEN}$((i+1))${NC}) ${name}"
            ((i++))
        done
        echo ""
        read -r -p "  > " pick
        [[ "$pick" =~ ^[0-9]+$ ]] || return
        ((pick--))
        (( pick >= 0 && pick < ${#skills[@]} )) || return
        skill_dir="${skills[$pick]}"
    fi

    if [[ ! -f "$skill_dir/SKILL.md" ]]; then
        ui_fail "No SKILL.md in $skill_dir"
        return 1
    fi
    if [[ ! -f "$skill_dir/eval.json" ]]; then
        ui_fail "No eval.json in $skill_dir — run: kmac skillopt init $skill_dir"
        return 1
    fi

    _ensure_anthropic_key || return 1
    _ensure_deps || return 1

    local extra_args=("$@")

    echo ""
    title_box "Skill Optimizer" "🧬"
    echo -e "  Skill:    ${CYAN}$(basename "$skill_dir")${NC}"
    echo -e "  File:     ${DIM}$skill_dir/SKILL.md${NC}"

    local target iterations samples
    target=$(python3 -c "import json; print(json.load(open('$skill_dir/eval.json')).get('targetRate',0.9))" 2>/dev/null)
    iterations=$(python3 -c "import json; print(json.load(open('$skill_dir/eval.json')).get('maxIterations',10))" 2>/dev/null)
    samples=$(python3 -c "import json; print(json.load(open('$skill_dir/eval.json')).get('samplesPerIteration',5))" 2>/dev/null)
    local tc_count
    tc_count=$(python3 -c "import json; print(len(json.load(open('$skill_dir/eval.json')).get('testCases',[])))" 2>/dev/null)

    echo -e "  Target:   ${GREEN}${target:-0.9}${NC} ($(echo "${target:-0.9}" | python3 -c "import sys; print(f'{float(sys.stdin.read())*100:.0f}%')"))"
    echo -e "  Iters:    ${iterations:-10} max"
    echo -e "  Samples:  ${samples:-5} per iteration"
    echo -e "  Tests:    ${tc_count:-0} cases"
    echo ""
    echo -e "  ${DIM}This will make many Claude API calls. Estimated cost: ~\$0.50-2.00${NC}"
    echo ""
    echo -e "  ${GREEN}r${NC}) Run    ${GREEN}e${NC}) Edit eval.json    ${GREEN}m${NC}) Cancel"
    echo ""
    read -r -n1 -p "  > " ch; echo ""

    case "$ch" in
        r|R)
            echo ""
            (cd "$ASSISTANT_DIR" && ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" npx tsx src/optimizer.ts "$skill_dir" "${extra_args[@]}")
            ;;
        e|E) ${EDITOR:-vim} "$skill_dir/eval.json" ;;
    esac
}

do_status() {
    local skill_dir="${1:-}"

    if [[ -z "$skill_dir" ]]; then
        local skills=()
        while IFS= read -r d; do
            [[ -n "$d" ]] && skills+=("$d")
        done < <(_list_skills)

        if (( ${#skills[@]} == 0 )); then
            ui_warn "No skills found"
            return
        fi

        title_box "Skill Optimizer — Status" "📊"
        echo ""
        printf "  ${BOLD}%-20s %-12s %-12s %s${NC}\n" "Skill" "SKILL.md" "eval.json" "History"
        echo -e "  ${DIM}$(printf '─%.0s' {1..60})${NC}"

        for s in "${skills[@]}"; do
            local name; name=$(basename "$s")
            local has_skill="✓" has_eval="${DIM}○${NC}" history="${DIM}-${NC}"
            [[ -f "$s/eval.json" ]] && has_eval="${GREEN}✓${NC}"
            if [[ -f "$s/optimizer-history.jsonl" ]]; then
                local lines; lines=$(wc -l < "$s/optimizer-history.jsonl" | tr -d ' ')
                local last_rate
                last_rate=$(tail -1 "$s/optimizer-history.jsonl" | python3 -c "import sys,json; print(f\"{json.load(sys.stdin).get('overallRate',0)*100:.0f}%\")" 2>/dev/null)
                history="${GREEN}${lines} iters${NC} (${last_rate:-?})"
            fi
            printf "  %-20s %-12s %-12b %b\n" "$name" "$has_skill" "$has_eval" "$history"
        done
        echo ""
        return
    fi

    if [[ ! -f "$skill_dir/optimizer-history.jsonl" ]]; then
        ui_warn "No optimization history for $(basename "$skill_dir")"
        return
    fi

    title_box "Optimization History — $(basename "$skill_dir")" "📊"
    echo ""
    printf "  ${BOLD}%-5s %-8s %-8s %-8s %s${NC}\n" "Iter" "Rate" "Action" "Passed" "Changes"
    echo -e "  ${DIM}$(printf '─%.0s' {1..65})${NC}"

    while IFS= read -r line; do
        local iter rate action passed total changes
        eval "$(echo "$line" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"iter={d.get('iteration',0)}\")
print(f\"rate={d.get('overallRate',0)*100:.0f}%\")
print(f\"action={d.get('action','?')}\")
print(f\"passed={d.get('passedTests',0)}\")
print(f\"total={d.get('totalTests',0)}\")
print(f\"changes='{d.get('changes','')[:40]}'\")
" 2>/dev/null)"
        local color="$NC"
        case "$action" in
            keep) color="$GREEN" ;;
            discard) color="$YELLOW" ;;
            baseline) color="$CYAN" ;;
        esac
        printf "  %-5s %-8s ${color}%-8s${NC} %-8s %s\n" "$iter" "$rate" "$action" "${passed}/${total}" "$changes"
    done < "$skill_dir/optimizer-history.jsonl"
    echo ""
}

do_interactive() {
    while true; do
        clear
        title_box "Skill Optimizer" "🧬"
        echo ""
        echo -e "  ${BOLD}What is this?${NC}"
        echo -e "  Applies the Karpathy autoresearch method to your SKILL.md"
        echo -e "  files. Runs test prompts, scores outputs against criteria,"
        echo -e "  and iteratively rewrites the skill until it hits a target"
        echo -e "  success rate — turning 70% skills into 95% skills."
        echo ""
        echo -e "  ${BOLD}How to use it:${NC}"
        echo -e "  ${DIM}1.${NC} Press ${GREEN}i${NC} to create a skill or generate eval criteria"
        echo -e "  ${DIM}2.${NC} Review the eval.json (edit test cases and criteria)"
        echo -e "  ${DIM}3.${NC} Press ${GREEN}r${NC} to run the optimization loop"
        echo -e "  ${DIM}4.${NC} Press ${GREEN}s${NC} to check progress and results"
        echo ""
        echo -e "  ${DIM}Skills dir: $SKILLS_DIR${NC}"
        echo ""

        local skill_count=0 eval_count=0
        for d in "$SKILLS_DIR"/*/; do
            [[ -f "$d/SKILL.md" ]] && ((skill_count++))
            [[ -f "$d/eval.json" ]] && ((eval_count++))
        done 2>/dev/null

        echo -e "  ${DIM}┌─ status ──────────────────────────────────────────┐${NC}"
        echo -e "  ${DIM}│${NC}  Skills: ${skill_count}   With evals: ${eval_count}                       ${DIM}│${NC}"
        echo -e "  ${DIM}└────────────────────────────────────────────────────┘${NC}"
        echo ""
        echo -e "   ${GREEN}i${NC}  Init / Create Skill     ${GREEN}r${NC}  Run Optimizer"
        echo -e "   ${GREEN}s${NC}  Status / History        ${GREEN}e${NC}  Edit Skill"
        echo ""
        echo -e "  ${DIM}m) Back to main menu${NC}"
        echo ""
        read -r -n1 -p "  > " ch; echo ""
        case "$ch" in
            i) do_init; read -r -n1 -p "  Press any key..."; echo "" ;;
            r) do_run; read -r -n1 -p "  Press any key..."; echo "" ;;
            s) do_status; read -r -n1 -p "  Press any key..."; echo "" ;;
            e)
                local skills=()
                while IFS= read -r d; do
                    [[ -n "$d" ]] && skills+=("$d")
                done < <(_list_skills)
                if (( ${#skills[@]} > 0 )); then
                    echo ""
                    local i=0
                    for s in "${skills[@]}"; do
                        echo -e "  ${GREEN}$((i+1))${NC}) $(basename "$s")"
                        ((i++))
                    done
                    echo ""
                    read -r -p "  > " pick
                    [[ "$pick" =~ ^[0-9]+$ ]] || continue
                    ((pick--))
                    (( pick >= 0 && pick < ${#skills[@]} )) && ${EDITOR:-vim} "${skills[$pick]}/SKILL.md"
                fi
                ;;
            m|M) return ;;
        esac
    done
}

# ─── Routing ──────────────────────────────────────────────────────────

cmd="${1:-menu}"; shift 2>/dev/null

case "$cmd" in
    init)       do_init "$@" ;;
    run)        do_run "$@" ;;
    status|st)  do_status "$@" ;;
    menu)       do_interactive ;;
    help|--help|-h)
        echo "Skill Optimizer — iteratively refine SKILL.md files"
        echo ""
        echo "Usage: kmac skillopt <command> [skill-dir]"
        echo ""
        echo "  init [skill-dir]    Create a new skill or generate eval.json"
        echo "  run [skill-dir]     Run the optimization loop"
        echo "  status [skill-dir]  Show optimization history"
        echo ""
        echo "Run with no args for the interactive menu."
        ;;
    *)
        # If first arg is a directory, treat as 'run'
        if [[ -d "$cmd" ]]; then
            do_run "$cmd" "$@"
        else
            echo "Unknown: $cmd — try: kmac skillopt help"
            exit 1
        fi
        ;;
esac

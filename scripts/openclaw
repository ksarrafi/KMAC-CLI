#!/bin/bash
# openclaw — Manage the OpenClaw personal AI assistant
# https://github.com/openclaw/openclaw
# Usage: openclaw install|start|stop|status|doctor|onboard|devices|channels|open|logs|update|help

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_ui.sh"

OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"
OPENCLAW_PORT="${OPENCLAW_PORT:-18789}"
OPENCLAW_URL="http://127.0.0.1:${OPENCLAW_PORT}"
OPENCLAW_WS="ws://127.0.0.1:${OPENCLAW_PORT}"
CONFIG_DIR="$HOME/.config/kmac/openclaw"
LOG_FILE="$CONFIG_DIR/gateway.log"
PID_FILE="$CONFIG_DIR/gateway.pid"

_ensure_dirs() {
    mkdir -p "$CONFIG_DIR"
    chmod 700 "$CONFIG_DIR"
}

_is_installed() {
    command -v openclaw &>/dev/null
}

_check_node() {
    if ! command -v node &>/dev/null; then
        ui_fail "Node.js is required (>= 22.16, recommended 24)"
        return 1
    fi
    local ver; ver=$(node --version 2>/dev/null | sed 's/^v//')
    local major; major="${ver%%.*}"
    if (( major < 22 )); then
        ui_warn "Node $ver detected — OpenClaw needs >= 22.16 (24 recommended)"
        echo "  Upgrade: nvm install 24 && nvm use 24"
        return 1
    fi
}

_gateway_pid() {
    local pid=""
    [[ -f "$PID_FILE" ]] && read -r pid < "$PID_FILE" 2>/dev/null
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
        echo "$pid"
        return
    fi
    # Fallback: check for running gateway process
    pgrep -f "openclaw.*gateway" 2>/dev/null | head -1
}

_gateway_healthy() {
    curl -sf --max-time 3 "${OPENCLAW_URL}/health" &>/dev/null 2>&1 ||
    curl -sf --max-time 3 "${OPENCLAW_URL}/api/health" &>/dev/null 2>&1
}

do_install() {
    _check_node || return 1

    if _is_installed; then
        local ver; ver=$(openclaw --version 2>/dev/null)
        echo ""
        echo -e "  OpenClaw is already installed: ${GREEN}${ver}${NC}"
        echo ""
        echo -e "  ${GREEN}u${NC}) Update to latest"
        echo -e "  ${GREEN}r${NC}) Reinstall"
        echo -e "  ${DIM}m) Back${NC}"
        echo ""
        read -r -n1 -p "  > " ch; echo ""
        case "$ch" in
            u|U) do_update ;;
            r|R)
                ui_info "Reinstalling OpenClaw..."
                npm install -g openclaw@latest
                ;;
        esac
        return
    fi

    ui_info "Installing OpenClaw..."
    echo ""
    echo -e "  ${DIM}npm install -g openclaw@latest${NC}"
    echo ""
    npm install -g openclaw@latest
    local rc=$?
    if (( rc == 0 )) && _is_installed; then
        ui_success "OpenClaw installed: $(openclaw --version 2>/dev/null)"
        echo ""
        echo -e "  Run ${GREEN}kmac openclaw onboard${NC} to set up."
    else
        ui_fail "Installation failed (exit $rc)"
        echo "  Try: pnpm add -g openclaw@latest"
    fi
}

do_onboard() {
    if ! _is_installed; then
        ui_warn "OpenClaw not installed"
        echo -e "  Run ${GREEN}kmac openclaw install${NC} first."
        return 1
    fi

    ui_info "Starting OpenClaw onboard wizard..."
    echo -e "  ${DIM}This will guide you through gateway, workspace, channels, and skills.${NC}"
    echo ""
    openclaw onboard --install-daemon
}

do_start() {
    if ! _is_installed; then
        ui_warn "OpenClaw not installed"
        echo -e "  Run ${GREEN}kmac openclaw install${NC} first."
        return 1
    fi

    _ensure_dirs
    local pid; pid=$(_gateway_pid)
    if [[ -n "$pid" ]]; then
        ui_warn "Gateway already running (PID $pid)"
        return 0
    fi

    local extra_args=()
    [[ "${1:-}" == "--verbose" ]] && extra_args+=("--verbose")

    ui_info "Starting OpenClaw gateway on port ${OPENCLAW_PORT}..."
    nohup openclaw gateway --port "$OPENCLAW_PORT" "${extra_args[@]}" >> "$LOG_FILE" 2>&1 &
    local new_pid=$!
    echo "$new_pid" > "$PID_FILE"

    local attempts=0
    while (( attempts < 20 )); do
        if _gateway_healthy; then
            ui_success "Gateway started (PID $new_pid)"
            echo ""
            echo "  WebSocket: ${OPENCLAW_WS}"
            echo "  Control:   ${OPENCLAW_URL}"
            echo "  Logs:      $LOG_FILE"
            echo ""
            return 0
        fi
        sleep 1
        ((attempts++))
    done

    ui_fail "Gateway failed to start within 20s — check $LOG_FILE"
    return 1
}

do_stop() {
    local pid; pid=$(_gateway_pid)
    if [[ -z "$pid" ]]; then
        ui_warn "Gateway not running"
        rm -f "$PID_FILE"
        return 0
    fi

    ui_info "Stopping gateway (PID $pid)..."
    kill "$pid" 2>/dev/null
    local i=0
    while (( i < 10 )) && kill -0 "$pid" 2>/dev/null; do
        sleep 0.5
        ((i++))
    done
    if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null
    fi
    rm -f "$PID_FILE"
    ui_success "Gateway stopped"
}

do_restart() {
    do_stop
    sleep 1
    do_start "$@"
}

do_status() {
    echo ""
    echo -e "  ${BOLD}OpenClaw Status${NC}"
    echo ""

    if _is_installed; then
        local ver; ver=$(openclaw --version 2>/dev/null)
        echo -e "  Installed:  ${GREEN}✓${NC} ${ver}"
    else
        echo -e "  Installed:  ${RED}✗${NC} Not installed"
        return
    fi

    echo -e "  Home:       ${DIM}${OPENCLAW_HOME}${NC}"

    if [[ -f "$OPENCLAW_HOME/openclaw.json" ]]; then
        echo -e "  Config:     ${GREEN}✓${NC} openclaw.json"
    else
        echo -e "  Config:     ${DIM}○${NC} Not configured ${DIM}(run: kmac openclaw onboard)${NC}"
    fi

    local pid; pid=$(_gateway_pid)
    if [[ -n "$pid" ]]; then
        echo -e "  Gateway:    ${GREEN}● Running${NC} (PID $pid)"
        echo -e "  Endpoint:   ${OPENCLAW_WS}"
        if _gateway_healthy; then
            echo -e "  Health:     ${GREEN}✓${NC} OK"
        else
            echo -e "  Health:     ${YELLOW}!${NC} Not responding"
        fi
    else
        echo -e "  Gateway:    ${DIM}○ Stopped${NC}"
    fi

    if [[ -d "$OPENCLAW_HOME/workspace" ]]; then
        echo -e "  Workspace:  ${GREEN}✓${NC} ${OPENCLAW_HOME}/workspace"
    else
        echo -e "  Workspace:  ${DIM}○${NC} Not created"
    fi
}

do_doctor() {
    if ! _is_installed; then
        ui_warn "OpenClaw not installed"
        return 1
    fi
    ui_info "Running OpenClaw doctor..."
    openclaw doctor
}

do_devices() {
    if ! _is_installed; then
        ui_warn "OpenClaw not installed"
        return 1
    fi

    echo ""
    echo -e "  ${BOLD}Device Management${NC}"
    echo ""
    echo -e "  ${GREEN}l${NC}) List devices"
    echo -e "  ${GREEN}a${NC}) Approve pending device"
    echo -e "  ${GREEN}p${NC}) Pair new device"
    echo -e "  ${DIM}m) Back${NC}"
    echo ""
    read -r -n1 -p "  > " ch; echo ""
    case "$ch" in
        l|L) openclaw devices list 2>/dev/null || openclaw devices 2>/dev/null ;;
        a|A) openclaw devices approve --latest 2>/dev/null || echo "  No pending devices." ;;
        p|P) openclaw devices pair 2>/dev/null ;;
    esac
}

do_channels() {
    if ! _is_installed; then
        ui_warn "OpenClaw not installed"
        return 1
    fi

    echo ""
    echo -e "  ${BOLD}Channel Management${NC}"
    echo ""
    echo -e "  ${GREEN}l${NC}) Login / link channel"
    echo -e "  ${GREEN}s${NC}) Channel status"
    echo -e "  ${DIM}m) Back${NC}"
    echo ""
    read -r -n1 -p "  > " ch; echo ""
    case "$ch" in
        l|L)
            echo ""
            echo -e "  Available channels:"
            echo -e "  ${DIM}whatsapp, telegram, slack, discord, googlechat, signal,${NC}"
            echo -e "  ${DIM}bluebubbles, imessage, irc, msteams, matrix, webchat, ...${NC}"
            echo ""
            read -r -p "  Channel name: " cname
            [[ -n "$cname" ]] && openclaw channels login --channel "$cname"
            ;;
        s|S) openclaw channels status 2>/dev/null || openclaw channels 2>/dev/null ;;
    esac
}

do_open() {
    if _gateway_healthy; then
        open "${OPENCLAW_URL}" 2>/dev/null || xdg-open "${OPENCLAW_URL}" 2>/dev/null
        ui_success "Opened Control UI at ${OPENCLAW_URL}"
    else
        ui_warn "Gateway not responding — start it first"
    fi
}

do_logs() {
    if [[ "${1:-}" == "-f" || "${1:-}" == "follow" ]]; then
        if [[ -f "$LOG_FILE" ]]; then
            tail -f "$LOG_FILE"
        else
            ui_warn "No log file — try: openclaw gateway --verbose"
        fi
    else
        local lines="${1:-50}"
        if [[ -f "$LOG_FILE" ]]; then
            tail -n "$lines" "$LOG_FILE"
        else
            ui_warn "No log file at $LOG_FILE"
        fi
    fi
}

do_update() {
    if ! _is_installed; then
        ui_warn "OpenClaw not installed"
        return 1
    fi
    ui_info "Updating OpenClaw..."
    openclaw update --channel stable 2>/dev/null || npm install -g openclaw@latest
    local rc=$?
    if (( rc == 0 )); then
        ui_success "Updated to $(openclaw --version 2>/dev/null)"
    else
        ui_fail "Update failed"
    fi
}

do_agent() {
    if ! _is_installed; then
        ui_warn "OpenClaw not installed"
        return 1
    fi
    shift 2>/dev/null || true
    openclaw agent "$@"
}

do_send() {
    if ! _is_installed; then
        ui_warn "OpenClaw not installed"
        return 1
    fi
    shift 2>/dev/null || true
    openclaw message send "$@"
}

do_interactive() {
    while true; do
        clear
        title_box "OpenClaw — Personal AI Assistant" "🦞"
        do_status
        echo ""
        echo -e "  ${GREEN}i${NC}) Install / Update      ${GREEN}o${NC}) Onboard Wizard"
        echo -e "  ${GREEN}s${NC}) Start Gateway          ${GREEN}S${NC}) Stop Gateway"
        echo -e "  ${GREEN}r${NC}) Restart                ${GREEN}w${NC}) Open Control UI"
        echo -e "  ${GREEN}d${NC}) Doctor                 ${GREEN}v${NC}) Devices"
        echo -e "  ${GREEN}c${NC}) Channels               ${GREEN}l${NC}) Logs ${DIM}(follow)${NC}"
        echo -e "  ${GREEN}p${NC}) Paperclip Connect      ${GREEN}a${NC}) Agent Chat"
        echo ""
        echo -e "  ${DIM}m) Back${NC}"
        echo ""
        read -r -n1 -p "  > " ch; echo ""
        case "$ch" in
            i) do_install; read -r -n1 -p "  Press any key..."; echo "" ;;
            o) do_onboard; read -r -n1 -p "  Press any key..."; echo "" ;;
            s) do_start; read -r -n1 -p "  Press any key..."; echo "" ;;
            S) do_stop; read -r -n1 -p "  Press any key..."; echo "" ;;
            r) do_restart; read -r -n1 -p "  Press any key..."; echo "" ;;
            w) do_open ;;
            d) do_doctor; read -r -n1 -p "  Press any key..."; echo "" ;;
            v) do_devices; read -r -n1 -p "  Press any key..."; echo "" ;;
            c) do_channels; read -r -n1 -p "  Press any key..."; echo "" ;;
            l) do_logs -f ;;
            p) bash "$SCRIPT_DIR/paperclip"; ;;
            a)
                if ! _is_installed; then
                    ui_warn "OpenClaw not installed"; read -r -n1 -p "  Press any key..."; echo ""
                else
                    echo -e "  ${DIM}Type your message (Ctrl+C to exit):${NC}"
                    echo ""
                    read -r -p "  Message: " msg
                    [[ -n "$msg" ]] && openclaw agent --message "$msg"
                    read -r -n1 -p "  Press any key..."; echo ""
                fi
                ;;
            m|M) return ;;
        esac
    done
}

do_help() {
    cat <<'HELP'
OpenClaw — Personal AI Assistant (https://github.com/openclaw/openclaw)

Usage: kmac openclaw <command>

Commands:
  install             Install OpenClaw globally via npm
  onboard             Run the guided onboard wizard
  start [--verbose]   Start the gateway daemon
  stop                Stop the gateway
  restart             Restart the gateway
  status              Show installation and gateway status
  doctor              Run OpenClaw diagnostics
  open                Open the Control UI in browser
  devices             List/approve/pair devices
  channels            Manage messaging channels
  logs [N|-f]         Show gateway logs (default 50, -f to follow)
  update              Update to latest stable release
  agent [args]        Run the agent CLI
  send [args]         Send a message via OpenClaw

Environment:
  OPENCLAW_HOME       Config directory (default: ~/.openclaw)
  OPENCLAW_PORT       Gateway port (default: 18789)
HELP
}

# ─── CLI Router ─────────────────────────────────────────────────────────────
case "${1:-}" in
    install)     do_install ;;
    onboard)     do_onboard ;;
    start)       shift; do_start "$@" ;;
    stop)        do_stop ;;
    restart)     shift; do_restart "$@" ;;
    status)      do_status ;;
    doctor)      do_doctor ;;
    open)        do_open ;;
    devices)     do_devices ;;
    channels)    do_channels ;;
    logs)        shift; do_logs "$@" ;;
    update)      do_update ;;
    agent)       do_agent "$@" ;;
    send)        do_send "$@" ;;
    help|--help|-h) do_help ;;
    "")          do_interactive ;;
    *)           ui_fail "Unknown command: $1"; do_help; exit 1 ;;
esac

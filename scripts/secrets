#!/bin/bash
# secrets — credential manager and integration hub
# Usage: secrets              (interactive menu)
#        secrets list          (show all credentials)
#        secrets get <name>    (retrieve a secret)
#        secrets set <name>    (store a secret)
#        secrets export        (load all into shell)
#        secrets add           (register new integration)
#        secrets backend       (switch vault backend)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_ui.sh"
source "$SCRIPT_DIR/_vault.sh"
[[ -z "${KMAC_PLATFORM_LOADED:-}" ]] && source "$SCRIPT_DIR/_platform.sh" 2>/dev/null || true

_open_url() {
    if command -v platform_open &>/dev/null; then
        platform_open "$1"
    elif [[ "$(uname)" == "Darwin" ]]; then
        open "$1"
    else
        xdg-open "$1" 2>/dev/null || echo "Open: $1"
    fi
}

# ─── Guided Setup: URLs, steps, and validation for known services ────────

_guide_url() {
    case "$1" in
        anthropic)    echo "https://console.anthropic.com/settings/keys" ;;
        openai)       echo "https://platform.openai.com/api-keys" ;;
        google-ai)    echo "https://aistudio.google.com/app/apikey" ;;
        groq)         echo "https://console.groq.com/keys" ;;
        github)       echo "https://github.com/settings/tokens?type=beta" ;;
        gitlab)       echo "https://gitlab.com/-/user_settings/personal_access_tokens" ;;
        npm)          echo "https://www.npmjs.com/settings/~/tokens" ;;
        docker-hub)   echo "https://hub.docker.com/settings/security" ;;
        ngrok)        echo "https://dashboard.ngrok.com/get-started/your-authtoken" ;;
        telegram-bot) echo "https://t.me/BotFather" ;;
        aws-access-key|aws-secret-key) echo "https://console.aws.amazon.com/iam/home#/security_credentials" ;;
        vercel)       echo "https://vercel.com/account/tokens" ;;
        supabase)     echo "https://supabase.com/dashboard/account/tokens" ;;
        slack-webhook) echo "https://api.slack.com/apps" ;;
        sentry-dsn)   echo "https://sentry.io/settings/projects/" ;;
        sendgrid)     echo "https://app.sendgrid.com/settings/api_keys" ;;
        *)            echo "" ;;
    esac
}

_guide_steps() {
    case "$1" in
        anthropic)
            echo "  ${BOLD}How to get your Anthropic API key:${NC}"
            echo "  ${DIM}1. Sign up or log in at console.anthropic.com${NC}"
            echo "  ${DIM}2. Go to Settings → API Keys${NC}"
            echo "  ${DIM}3. Click 'Create Key', give it a name${NC}"
            echo "  ${DIM}4. Copy the key (starts with sk-ant-)${NC}" ;;
        openai)
            echo "  ${BOLD}How to get your OpenAI API key:${NC}"
            echo "  ${DIM}1. Sign up or log in at platform.openai.com${NC}"
            echo "  ${DIM}2. Go to API Keys${NC}"
            echo "  ${DIM}3. Click '+ Create new secret key'${NC}"
            echo "  ${DIM}4. Copy the key (starts with sk-)${NC}" ;;
        google-ai)
            echo "  ${BOLD}How to get your Google AI key:${NC}"
            echo "  ${DIM}1. Go to Google AI Studio${NC}"
            echo "  ${DIM}2. Click 'Get API key' → 'Create API key'${NC}"
            echo "  ${DIM}3. Copy the key${NC}" ;;
        github)
            echo "  ${BOLD}How to get your GitHub token:${NC}"
            echo "  ${DIM}1. Sign in at github.com${NC}"
            echo "  ${DIM}2. Go to Settings → Developer settings → Fine-grained tokens${NC}"
            echo "  ${DIM}3. Click 'Generate new token'${NC}"
            echo "  ${DIM}4. Select scopes (repo, read:org recommended)${NC}"
            echo "  ${DIM}5. Copy the token (starts with github_pat_)${NC}" ;;
        ngrok)
            echo "  ${BOLD}How to get your ngrok auth token:${NC}"
            echo "  ${DIM}1. Sign up at ngrok.com (free)${NC}"
            echo "  ${DIM}2. Go to Your Authtoken in the dashboard${NC}"
            echo "  ${DIM}3. Copy the token${NC}" ;;
        telegram-bot)
            echo "  ${BOLD}How to create a Telegram bot:${NC}"
            echo "  ${DIM}1. Open Telegram and message @BotFather${NC}"
            echo "  ${DIM}2. Send /newbot and follow the prompts${NC}"
            echo "  ${DIM}3. Copy the token BotFather gives you${NC}" ;;
        *)
            echo "  ${BOLD}Get your ${1} credentials:${NC}" ;;
    esac
}

_validate_key() {
    local svc="$1" key="$2"
    case "$svc" in
        anthropic)
            local resp
            resp=$(curl -sf --max-time 5 -o /dev/null -w "%{http_code}" \
                https://api.anthropic.com/v1/messages \
                -H "x-api-key: $key" \
                -H "anthropic-version: 2023-06-01" \
                -H "content-type: application/json" \
                -d '{"model":"claude-haiku-4-5","max_tokens":1,"messages":[{"role":"user","content":"hi"}]}' 2>/dev/null)
            # 200 = valid, 401 = bad key, anything else = probably valid (rate limit, etc)
            if [[ "$resp" == "401" ]]; then return 1; fi
            return 0 ;;
        openai)
            local resp
            resp=$(curl -sf --max-time 5 -o /dev/null -w "%{http_code}" \
                https://api.openai.com/v1/models \
                -H "Authorization: Bearer $key" 2>/dev/null)
            [[ "$resp" == "401" ]] && return 1
            return 0 ;;
        github)
            local resp
            resp=$(curl -sf --max-time 5 -o /dev/null -w "%{http_code}" \
                https://api.github.com/user \
                -H "Authorization: Bearer $key" 2>/dev/null)
            [[ "$resp" == "401" ]] && return 1
            return 0 ;;
        ngrok)
            local resp
            resp=$(curl -sf --max-time 5 -o /dev/null -w "%{http_code}" \
                https://api.ngrok.com/tunnels \
                -H "Authorization: Bearer $key" \
                -H "Ngrok-Version: 2" 2>/dev/null)
            [[ "$resp" == "401" ]] && return 1
            return 0 ;;
        *) return 0 ;;  # no validation available — assume good
    esac
}

# Guided setup for a single service: show steps, open browser, validate
guided_setup() {
    local svc="$1"
    local url
    url=$(_guide_url "$svc")

    echo ""
    echo -e "$(_guide_steps "$svc")"
    echo ""

    if [[ -n "$url" ]]; then
        echo -e "  ${CYAN}▸${NC} Opening ${DIM}${url}${NC}"
        echo ""
        _open_url "$url" 2>/dev/null
        sleep 1
    fi

    echo -e "  ${DIM}Paste the key below (hidden input). Press Enter when done.${NC}"
    echo ""
    read -r -s -p "  Key: " value
    echo ""

    if [[ -z "$value" ]]; then
        echo -e "  ${DIM}Skipped.${NC}"
        return 1
    fi

    # Validate
    echo ""
    printf '  %s⠋%s Validating...' "$CYAN" "$NC"
    if _validate_key "$svc" "$value"; then
        printf '\r  %s✓%s Key is valid  \n' "$GREEN" "$NC"
    else
        printf '\r  %s✗%s Key was rejected — double-check and try again\n' "$RED" "$NC"
        echo ""
        read -r -n1 -p "  Save anyway? (y/N) > " yn; echo ""
        [[ "$yn" != [yY] ]] && return 1
    fi

    if vault_set "$svc" "$value"; then
        echo -e "  ${GREEN}✓ Saved: ${BOLD}${svc}${NC}"
        return 0
    else
        echo -e "  ${RED}✗ Failed to save${NC}"
        return 1
    fi
}

# ─── Category display names ──────────────────────────────────────────────

_cat_label() {
    case "$1" in
        ai)       echo "AI & LLMs" ;;
        devops)   echo "DevOps & Code" ;;
        docker)   echo "Docker & Containers" ;;
        infra)    echo "Infrastructure" ;;
        cloud)    echo "Cloud & Hosting" ;;
        services) echo "Services & APIs" ;;
        mcp)      echo "MCP Servers" ;;
        custom)   echo "Custom" ;;
        *)        echo "$1" ;;
    esac
}

_cat_icon() {
    case "$1" in
        ai)       echo "🤖" ;;
        devops)   echo "⚙️"  ;;
        docker)   echo "🐳" ;;
        infra)    echo "🔧" ;;
        cloud)    echo "☁️"  ;;
        services) echo "🔗" ;;
        mcp)      echo "🧩" ;;
        custom)   echo "🔑" ;;
        *)        echo "•"  ;;
    esac
}

# ─── Status Dashboard ────────────────────────────────────────────────────

do_dashboard() {
    title_box "Credential Manager" "🔐"

    local backend
    backend=$(_vault_backend)
    echo -e "  ${BOLD}Backend:${NC} ${CYAN}${backend}${NC}"
    case "$backend" in
        keychain)
            echo -e "  ${DIM}Secrets stored in macOS Keychain (hardware-backed)${NC}" ;;
        file)
            echo -e "  ${DIM}Secrets stored in encrypted vault (AES-256, ~/.config/kmac/vault.enc)${NC}" ;;
        docker)
            if _docker_vault_running 2>/dev/null; then
                echo -e "  ${GREEN}●${NC} ${DIM}Docker vault container running on 127.0.0.1:${VAULT_DOCKER_PORT}${NC}"
            else
                echo -e "  ${YELLOW}○${NC} ${DIM}Docker vault container not running${NC}"
            fi ;;
    esac
    echo ""

    _vault_load_registry
    _vault_migrate_legacy 2>/dev/null

    local configured=0 total=${#_REG_SERVICES[@]}
    local prev_cat=""

    for (( i=0; i<total; i++ )); do
        local svc="${_REG_SERVICES[$i]}"
        local cat="${_REG_CATEGORIES[$i]}"
        local env="${_REG_ENVVARS[$i]}"
        local desc="${_REG_DESCS[$i]}"

        if [[ "$cat" != "$prev_cat" ]]; then
            [[ -n "$prev_cat" ]] && echo ""
            echo -e "  $(_cat_icon "$cat") ${BOLD}$(_cat_label "$cat")${NC}"
            echo -e "  ${DIM}$(printf '─%.0s' {1..48})${NC}"
            prev_cat="$cat"
        fi

        if vault_has "$svc" 2>/dev/null; then
            local masked
            masked=$(vault_get "$svc" 2>/dev/null)
            if [[ ${#masked} -gt 8 ]]; then
                masked="${masked:0:4}••••${masked: -4}"
            else
                masked="••••••••"
            fi
            printf "  ${GREEN}✓${NC} %-22s ${DIM}%s${NC}  ${DIM}[%s]${NC}\n" "$svc" "$masked" "$env"
            ((configured++))
        else
            printf "  ${RED}✗${NC} %-22s ${DIM}not set${NC}  ${DIM}[%s]${NC}\n" "$svc" "$env"
        fi
    done

    echo ""
    echo -e "  ${BOLD}${configured}/${total}${NC} integrations configured"
    echo ""
}

# ─── Set a credential ────────────────────────────────────────────────────

do_set() {
    local target="$1"

    if [[ -z "$target" ]]; then
        _vault_load_registry
        echo ""
        echo -e "  ${BOLD}Choose a credential to set:${NC}"
        echo ""

        local prev_cat=""
        for (( i=0; i<${#_REG_SERVICES[@]}; i++ )); do
            local svc="${_REG_SERVICES[$i]}"
            local cat="${_REG_CATEGORIES[$i]}"
            local desc="${_REG_DESCS[$i]}"

            if [[ "$cat" != "$prev_cat" ]]; then
                [[ -n "$prev_cat" ]] && echo ""
                echo -e "  $(_cat_icon "$cat") ${BOLD}$(_cat_label "$cat")${NC}"
                prev_cat="$cat"
            fi

            local status="${RED}✗${NC}"
            vault_has "$svc" 2>/dev/null && status="${GREEN}✓${NC}"
            printf "  %b %2d) %-22s ${DIM}%s${NC}\n" "$status" "$((i+1))" "$svc" "$desc"
        done

        echo ""
        echo -e "  ${DIM}Or type a name to create a new integration${NC}"
        echo ""
        read -r -p "  Choose [1-${#_REG_SERVICES[@]}] or name: " choice

        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#_REG_SERVICES[@]} )); then
            target="${_REG_SERVICES[$((choice-1))]}"
        elif [[ -n "$choice" ]]; then
            target="$choice"
        else
            return
        fi
    fi

    # Show current value if it exists
    if vault_has "$target" 2>/dev/null; then
        local cur
        cur=$(vault_get "$target" 2>/dev/null)
        local show="${cur:0:4}••••"
        echo ""
        echo -e "  ${DIM}Current value: ${show}${NC}"
        echo -e "  ${DIM}Setting a new value will overwrite it.${NC}"
    fi

    # Use guided flow if we have a guide for this service
    local url
    url=$(_guide_url "$target")
    if [[ -n "$url" ]]; then
        guided_setup "$target"
    else
        # Fallback: simple paste flow
        echo ""
        echo -e "  Setting: ${BOLD}${target}${NC}"

        _vault_load_registry
        local found_desc=""
        for (( i=0; i<${#_REG_SERVICES[@]}; i++ )); do
            if [[ "${_REG_SERVICES[$i]}" == "$target" ]]; then
                found_desc="${_REG_DESCS[$i]}"
                break
            fi
        done
        [[ -n "$found_desc" ]] && echo -e "  ${DIM}${found_desc}${NC}"

        echo ""
        read -r -s -p "  Paste value (hidden): " value
        echo ""

        if [[ -z "$value" ]]; then
            echo -e "  ${DIM}Cancelled.${NC}"
            return
        fi

        if vault_set "$target" "$value"; then
            echo -e "  ${GREEN}✓ Saved: ${target}${NC}"
        else
            echo -e "  ${RED}✗ Failed to save${NC}"
        fi
    fi
}

# ─── Get a credential ────────────────────────────────────────────────────

do_get() {
    local target="$1"
    if [[ -z "$target" ]]; then
        read -r -p "  Service name: " target
    fi
    [[ -z "$target" ]] && return

    local val
    val=$(vault_get "$target" 2>/dev/null)
    if [[ -n "$val" ]]; then
        echo "$val"
    else
        echo -e "  ${RED}Not found: ${target}${NC}" >&2
        return 1
    fi
}

# ─── Delete a credential ─────────────────────────────────────────────────

do_delete() {
    _vault_load_registry
    echo ""
    echo -e "  ${BOLD}Remove a credential:${NC}"
    echo ""

    local -a stored=()
    for (( i=0; i<${#_REG_SERVICES[@]}; i++ )); do
        local svc="${_REG_SERVICES[$i]}"
        if vault_has "$svc" 2>/dev/null; then
            stored+=("$svc")
            printf "  %2d) ${YELLOW}%s${NC}\n" "${#stored[@]}" "$svc"
        fi
    done

    if (( ${#stored[@]} == 0 )); then
        echo -e "  ${DIM}No stored credentials to remove.${NC}"
        return
    fi

    echo ""
    read -r -p "  Choose [1-${#stored[@]}]: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#stored[@]} )); then
        local target="${stored[$((choice-1))]}"
        echo ""
        echo -e "  ${YELLOW}Delete ${BOLD}${target}${NC}${YELLOW}? This cannot be undone.${NC}"
        read -r -n1 -p "  Confirm (y/N): " yn; echo ""
        if [[ "$yn" == [yY] ]]; then
            vault_del "$target"
            echo -e "  ${GREEN}✓ Deleted: ${target}${NC}"
        fi
    fi
}

# ─── Export to shell ──────────────────────────────────────────────────────

do_export() {
    _vault_load_registry
    local exported=0
    for (( i=0; i<${#_REG_SERVICES[@]}; i++ )); do
        local svc="${_REG_SERVICES[$i]}"
        local env="${_REG_ENVVARS[$i]}"
        [[ -z "$env" ]] && continue
        if vault_export "$svc" "$env" 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} ${env}"
            ((exported++))
        fi
    done
    echo ""
    if (( exported > 0 )); then
        echo -e "  ${BOLD}${exported} variable(s) loaded${NC} ${DIM}(this session only)${NC}"
    else
        echo -e "  ${DIM}No credentials to export.${NC}"
    fi
}

# ─── Add new integration ─────────────────────────────────────────────────

do_add_integration() {
    echo ""
    echo -e "  ${BOLD}Register a New Integration${NC}"
    echo -e "  ${DIM}Add any API key, token, or secret to the vault${NC}"
    echo ""
    read -r -p "  Service name (e.g. my-api): " svc_name
    [[ -z "$svc_name" ]] && return

    echo ""
    echo -e "  ${BOLD}Category:${NC}"
    echo -e "   ${GREEN}1${NC}) AI & LLMs          ${GREEN}5${NC}) Cloud & Hosting"
    echo -e "   ${GREEN}2${NC}) DevOps & Code       ${GREEN}6${NC}) Services & APIs"
    echo -e "   ${GREEN}3${NC}) Docker & Containers  ${GREEN}7${NC}) MCP Servers"
    echo -e "   ${GREEN}4${NC}) Infrastructure      ${GREEN}8${NC}) Custom"
    echo ""
    read -r -p "  Category [1-8]: " cat_choice
    local category
    case "$cat_choice" in
        1) category="ai" ;;
        2) category="devops" ;;
        3) category="docker" ;;
        4) category="infra" ;;
        5) category="cloud" ;;
        6) category="services" ;;
        7) category="mcp" ;;
        *) category="custom" ;;
    esac

    echo ""
    read -r -p "  Environment variable name (e.g. MY_API_KEY): " env_name
    read -r -p "  Description: " desc

    vault_add_integration "$svc_name" "$category" "${env_name:-}" "${desc:-Custom integration}"
    echo -e "  ${GREEN}✓ Registered: ${svc_name}${NC}"
    echo ""

    echo -e "  Set the value now? (Y/n)"
    read -r -n1 -p "  > " yn; echo ""
    if [[ "$yn" != [nN] ]]; then
        do_set "$svc_name"
    fi
}

# ─── Remove integration from registry ────────────────────────────────────

do_remove_integration() {
    _vault_load_registry
    echo ""
    echo -e "  ${BOLD}Remove an integration:${NC} ${DIM}(removes both the registry entry and stored secret)${NC}"
    echo ""

    local -a custom=()
    for (( i=0; i<${#_REG_SERVICES[@]}; i++ )); do
        local svc="${_REG_SERVICES[$i]}"
        local cat="${_REG_CATEGORIES[$i]}"
        if [[ "$cat" == "custom" || "$cat" == "mcp" ]]; then
            custom+=("$svc")
            printf "  %2d) %s\n" "${#custom[@]}" "$svc"
        fi
    done

    if (( ${#custom[@]} == 0 )); then
        echo -e "  ${DIM}No custom integrations to remove.${NC}"
        echo -e "  ${DIM}(Built-in integrations cannot be removed, only their values can be deleted)${NC}"
        return
    fi

    echo ""
    read -r -p "  Choose [1-${#custom[@]}]: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#custom[@]} )); then
        local target="${custom[$((choice-1))]}"
        vault_remove_integration "$target"
        echo -e "  ${GREEN}✓ Removed: ${target}${NC}"
    fi
}

# ─── Switch backend ──────────────────────────────────────────────────────

do_backend() {
    local current
    current=$(_vault_backend)

    echo ""
    echo -e "  ${BOLD}Vault Backend${NC}"
    echo ""

    local kc_mark="${DIM}○${NC}" file_mark="${DIM}○${NC}" dock_mark="${DIM}○${NC}"
    case "$current" in
        keychain) kc_mark="${GREEN}●${NC}" ;;
        file)     file_mark="${GREEN}●${NC}" ;;
        docker)   dock_mark="${GREEN}●${NC}" ;;
    esac

    echo -e "  $kc_mark ${BOLD}macOS Keychain${NC}$( [[ $current == keychain ]] && echo " ${DIM}(active)${NC}" )"
    echo -e "    ${DIM}Hardware-backed, OS-managed, unlocked by login password.${NC}"
    echo -e "    ${DIM}Secrets survive reboots and app reinstalls.${NC}"
    echo ""
    echo -e "  $file_mark ${BOLD}Encrypted File Vault${NC}$( [[ $current == file ]] && echo " ${DIM}(active)${NC}" )"
    echo -e "    ${DIM}AES-256-CBC with PBKDF2. Stored at ~/.config/kmac/vault.enc${NC}"
    echo -e "    ${DIM}Portable — sync via iCloud, git, or USB. Protected by master password.${NC}"
    echo ""
    echo -e "  $dock_mark ${BOLD}Docker Vault${NC}$( [[ $current == docker ]] && echo " ${DIM}(active)${NC}" )"
    echo -e "    ${DIM}Containerized & isolated. Data in Docker volume (kmac-vault-data).${NC}"
    echo -e "    ${DIM}Portable — export the volume to move between machines.${NC}"
    if _docker_vault_running 2>/dev/null; then
        echo -e "    ${GREEN}Container: running${NC}"
    elif docker info &>/dev/null; then
        echo -e "    ${YELLOW}Container: stopped${NC}"
    else
        echo -e "    ${RED}Docker not available${NC}"
    fi

    echo ""
    echo -e "  ${GREEN}1${NC}) Use macOS Keychain"
    echo -e "  ${GREEN}2${NC}) Use Encrypted File Vault"
    echo -e "  ${GREEN}3${NC}) Use Docker Vault"
    echo -e "  ${GREEN}4${NC}) Initialize / reset file vault password"
    echo -e "  ${GREEN}5${NC}) Docker vault management"
    echo -e "  ${GREEN}m${NC}) Back"
    echo ""
    read -r -n1 -p "  > " choice; echo ""

    case "$choice" in
        1)
            export KMAC_VAULT_BACKEND="keychain"
            _write_backend_pref "keychain"
            echo -e "  ${GREEN}✓ Switched to macOS Keychain${NC}"
            ;;
        2)
            export KMAC_VAULT_BACKEND="file"
            _write_backend_pref "file"
            if [[ ! -f "$VAULT_FILE" ]]; then
                echo ""
                echo -e "  ${BOLD}Create a new vault:${NC}"
                echo -e "  ${DIM}Choose a strong master password. You'll need it every session.${NC}"
                echo ""
                read -r -s -p "  Master password: " pw1; echo ""
                read -r -s -p "  Confirm: " pw2; echo ""
                if [[ "$pw1" != "$pw2" || -z "$pw1" ]]; then
                    echo -e "  ${RED}Passwords don't match. Try again.${NC}"
                    return
                fi
                _vault_master_password="$pw1"
                _vault_encrypt "{}"
                echo -e "  ${GREEN}✓ Vault created at ${VAULT_FILE}${NC}"
            fi
            echo -e "  ${GREEN}✓ Switched to Encrypted File Vault${NC}"
            ;;
        3)
            if ! docker info &>/dev/null; then
                echo -e "  ${RED}Docker is not running. Start Docker Desktop first.${NC}"
                return
            fi
            echo -e "  ${DIM}Starting Docker vault container...${NC}"
            if docker_vault_start; then
                export KMAC_VAULT_BACKEND="docker"
                _write_backend_pref "docker"
                echo -e "  ${GREEN}✓ Switched to Docker Vault${NC}"
                echo -e "  ${DIM}Container: ${VAULT_DOCKER_CONTAINER}  Port: 127.0.0.1:${VAULT_DOCKER_PORT}${NC}"
            else
                echo -e "  ${RED}✗ Failed to start Docker vault${NC}"
            fi
            ;;
        4)
            echo ""
            echo -e "  ${YELLOW}This will create a new empty vault (existing vault data will be lost).${NC}"
            read -r -n1 -p "  Continue? (y/N): " yn; echo ""
            [[ "$yn" != [yY] ]] && return
            read -r -s -p "  New master password: " pw1; echo ""
            read -r -s -p "  Confirm: " pw2; echo ""
            if [[ "$pw1" != "$pw2" || -z "$pw1" ]]; then
                echo -e "  ${RED}Passwords don't match.${NC}"
                return
            fi
            _vault_master_password="$pw1"
            _vault_encrypt "{}"
            echo -e "  ${GREEN}✓ File vault initialized${NC}"
            ;;
        5)
            do_docker_vault_mgmt
            ;;
    esac
}

do_docker_vault_mgmt() {
    echo ""
    echo -e "  ${BOLD}Docker Vault Management${NC}"
    echo ""

    if _docker_vault_running 2>/dev/null; then
        echo -e "  Status: ${GREEN}running${NC}"
        local cid
        cid=$(docker inspect -f '{{.Id}}' "$VAULT_DOCKER_CONTAINER" 2>/dev/null)
        echo -e "  ${DIM}Container: ${cid:0:12}${NC}"
        echo -e "  ${DIM}Port: 127.0.0.1:${VAULT_DOCKER_PORT}${NC}"
        local vol_size
        vol_size=$(docker system df -v 2>/dev/null | grep "$VAULT_DOCKER_VOLUME" | awk '{print $3}' 2>/dev/null)
        [[ -n "$vol_size" ]] && echo -e "  ${DIM}Volume size: ${vol_size}${NC}"
    elif docker info &>/dev/null; then
        echo -e "  Status: ${YELLOW}stopped${NC}"
    else
        echo -e "  Status: ${RED}Docker not available${NC}"
    fi

    echo ""
    echo -e "  ${GREEN}1${NC}) Start vault container"
    echo -e "  ${GREEN}2${NC}) Stop vault container"
    echo -e "  ${GREEN}3${NC}) Rebuild image"
    echo -e "  ${GREEN}4${NC}) Backup volume → tarball"
    echo -e "  ${GREEN}5${NC}) Restore volume ← tarball"
    echo -e "  ${RED}6${NC}) Destroy (remove container + volume)"
    echo -e "  ${GREEN}m${NC}) Back"
    echo ""
    read -r -n1 -p "  > " choice; echo ""

    case "$choice" in
        1)
            echo -e "  ${DIM}Starting...${NC}"
            if docker_vault_start; then
                echo -e "  ${GREEN}✓ Vault container running${NC}"
            else
                echo -e "  ${RED}✗ Failed to start${NC}"
            fi
            ;;
        2)
            docker_vault_stop
            echo -e "  ${GREEN}✓ Vault container stopped${NC}"
            ;;
        3)
            echo -e "  ${DIM}Rebuilding image...${NC}"
            local script_dir
            script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
            docker rm -f "$VAULT_DOCKER_CONTAINER" &>/dev/null
            docker rmi "$VAULT_DOCKER_IMAGE" &>/dev/null
            docker build -t "$VAULT_DOCKER_IMAGE" "${script_dir}/../server/vault" 2>&1 | tail -1
            echo -e "  ${GREEN}✓ Image rebuilt${NC}"
            ;;
        4)
            local backup_file
            backup_file="$HOME/kmac-vault-backup-$(date +%Y%m%d-%H%M%S).tar.gz"
            echo -e "  ${DIM}Backing up volume to ${backup_file}...${NC}"
            docker_vault_stop 2>/dev/null
            docker run --rm -v "${VAULT_DOCKER_VOLUME}:/vault/data" \
                -v "$(dirname "$backup_file"):/backup" \
                alpine tar czf "/backup/$(basename "$backup_file")" -C /vault/data . 2>/dev/null
            echo -e "  ${GREEN}✓ Backup saved: ${backup_file}${NC}"
            echo -e "  ${DIM}Size: $(du -h "$backup_file" 2>/dev/null | awk '{print $1}')${NC}"
            ;;
        5)
            echo ""
            read -r -p "  Path to backup tarball: " tarball
            if [[ ! -f "$tarball" ]]; then
                echo -e "  ${RED}File not found.${NC}"
                return
            fi
            echo -e "  ${YELLOW}This will replace all secrets in the Docker vault.${NC}"
            read -r -n1 -p "  Continue? (y/N): " yn; echo ""
            [[ "$yn" != [yY] ]] && return
            docker_vault_stop 2>/dev/null
            docker run --rm -v "${VAULT_DOCKER_VOLUME}:/vault/data" \
                -v "$(cd "$(dirname "$tarball")" && pwd):/backup" \
                alpine sh -c "rm -rf /vault/data/* && tar xzf /backup/$(basename "$tarball") -C /vault/data" 2>/dev/null
            echo -e "  ${GREEN}✓ Volume restored from ${tarball}${NC}"
            ;;
        6)
            echo ""
            echo -e "  ${RED}${BOLD}WARNING:${NC} ${RED}This will delete the vault container, volume, and ALL secrets stored in it.${NC}"
            read -r -n1 -p "  Type 'y' to confirm: " yn; echo ""
            if [[ "$yn" == [yY] ]]; then
                docker_vault_destroy
                echo -e "  ${GREEN}✓ Docker vault destroyed${NC}"
                if [[ "$(_vault_backend)" == "docker" ]]; then
                    export KMAC_VAULT_BACKEND="auto"
                    _write_backend_pref "auto"
                    echo -e "  ${DIM}Backend reset to auto-detect.${NC}"
                fi
            fi
            ;;
    esac
}

_write_backend_pref() {
    mkdir -p "$VAULT_DIR"
    echo "$1" > "$VAULT_DIR/backend"
}

# Load saved backend preference
if [[ -f "$VAULT_DIR/backend" ]]; then
    _saved_backend=$(cat "$VAULT_DIR/backend" 2>/dev/null)
    [[ -n "$_saved_backend" ]] && export VAULT_BACKEND="$_saved_backend"
fi

# ─── Interactive Menu ─────────────────────────────────────────────────────

do_menu() {
    while true; do
        clear
        do_dashboard

        echo -e "  ${BOLD}Actions${NC}"
        echo -e "  ${DIM}$(printf '─%.0s' {1..48})${NC}"
        echo -e "   ${GREEN}s${NC})  Set / update a credential"
        echo -e "   ${GREEN}d${NC})  Delete a stored credential"
        echo -e "   ${GREEN}e${NC})  Export all to shell environment"
        echo -e "   ${GREEN}a${NC})  Add new integration (MCP, API, custom)"
        echo -e "   ${GREEN}r${NC})  Remove a custom integration"
        echo -e "   ${GREEN}b${NC})  Switch vault backend ${DIM}(Keychain / File / Docker)${NC}"
        menu_back
        read -r -n1 -p "  > " action; echo ""

        case "$action" in
            s|S) do_set ;;
            d|D) do_delete ;;
            e|E) do_export ;;
            a|A) do_add_integration ;;
            r|R) do_remove_integration ;;
            b|B) do_backend ;;
            m|M|"") return ;;
        esac

        echo ""
        [[ "$action" != [mM] ]] && pause
    done
}

# ─── CLI Entry Point ─────────────────────────────────────────────────────

# When sourced with _source_only, just define functions — don't run anything
[[ "${1:-}" == "_source_only" ]] && return 0 2>/dev/null || true

case "${1:-}" in
    _source_only)   ;; # already handled above
    list|ls)        do_dashboard ;;
    get)            do_get "$2" ;;
    set)            do_set "$2" ;;
    delete|del|rm)  do_delete ;;
    export)         do_export ;;
    add)            do_add_integration ;;
    remove)         do_remove_integration ;;
    backend)        do_backend ;;
    docker-start)   docker_vault_start && echo "Docker vault running." ;;
    docker-stop)    docker_vault_stop && echo "Docker vault stopped." ;;
    docker-status)
        if _docker_vault_running 2>/dev/null; then
            echo "Docker vault: running (127.0.0.1:${VAULT_DOCKER_PORT})"
        else
            echo "Docker vault: not running"
        fi ;;
    docker-backup)  do_docker_vault_mgmt ;;
    *)              do_menu ;;
esac

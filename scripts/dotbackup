#!/bin/bash
# dotbackup — backup/restore dotfiles + Claude config to iCloud
# Usage: dotbackup          (backup with diff preview)
#        dotbackup restore  (restore to new Mac)
#        dotbackup diff     (show what changed since last backup)
#        dotbackup hook     (install auto-backup on shell exit)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BACKUP_DIR="$TOOLKIT_DIR/dotfiles"
ACTION="${1:-backup}"

source "$SCRIPT_DIR/_ui.sh"
source "$SCRIPT_DIR/_agent-hook.sh" 2>/dev/null

# Aliases for backward compat within this script
G="$GREEN" Y="$YELLOW" D="$DIM" N="$NC"

DOTFILES=("$HOME/.zshrc" "$HOME/.gitconfig" "$HOME/.gitignore_global" "$HOME/.vimrc" "$HOME/.tmux.conf")
CLAUDE_ITEMS=("$HOME/.claude/agents" "$HOME/.claude/commands" "$HOME/.claude/settings.json" "$HOME/.claude/settings.local.json")

# Patterns that indicate secrets — these lines get scrubbed during backup
SECRET_PATTERNS=(
    'API_KEY="sk-'
    'SECRET.*=.*[A-Za-z0-9_-]{20}'
    'TOKEN="[A-Za-z0-9_-]{20}'
    'PASSWORD="[^"]*"'
    '_PASS="[^"]*"'
)

_scrub_secrets() {
    local file="$1"
    local tmp="${file}.scrubbed"
    cp "$file" "$tmp"
    for pat in "${SECRET_PATTERNS[@]}"; do
        if grep -qE "$pat" "$tmp" 2>/dev/null; then
            local count
            count=$(grep -cE "$pat" "$tmp" 2>/dev/null || echo 0)
            echo -e "  ${Y}!${N} Scrubbed $count secret line(s) matching: ${D}${pat%%=*}${N}"
        fi
    done
    sed -E '
        /API_KEY="sk-/s/="[^"]*"/="REDACTED_USE_KMAC_SECRETS"/
        /SECRET.*="[A-Za-z0-9_-]{20}/s/="[^"]*"/="REDACTED_USE_KMAC_SECRETS"/
        /TOKEN="[A-Za-z0-9_-]{20}/s/="[^"]*"/="REDACTED_USE_KMAC_SECRETS"/
        /PASSWORD="[^"]*"/s/="[^"]*"/="REDACTED_USE_KMAC_SECRETS"/
        /_PASS="[^"]*"/s/="[^"]*"/="REDACTED_USE_KMAC_SECRETS"/
    ' "$file" > "$tmp"
    echo "$tmp"
}

show_diff() {
    title_box "Dotfile Changes"
    echo -e "  ${DIM}Compare your current dotfiles against the last backup.${NC}"
    echo ""
    local changes=0
    for f in "${DOTFILES[@]}"; do
        local name
        name=$(basename "$f")
        local backed="$BACKUP_DIR/$name"
        if [[ -f "$f" && -f "$backed" ]]; then
            if ! diff -q "$f" "$backed" &>/dev/null; then
                echo -e "  ${Y}~${N} $name"
                diff --unified=3 "$backed" "$f" 2>/dev/null | head -20 | sed 's/^/    /'
                echo ""; ((changes++))
            fi
        elif [[ -f "$f" && ! -f "$backed" ]]; then
            echo -e "  ${G}+${N} $name (new — not in backup)"
            ((changes++))
        fi
    done
    (( changes == 0 )) && echo -e "  ${G}✓ All dotfiles match backup${N}"
    echo ""
}

do_backup() {
    mkdir -p "$BACKUP_DIR"
    title_box "Dotfile Backup"
    echo -e "  ${DIM}Copy dotfiles and Claude config into the toolkit repo. Secrets are scrubbed.${NC}"
    echo ""
    for f in "${DOTFILES[@]}"; do
        [[ -f "$f" ]] || continue
        local name
        name=$(basename "$f")
        local dest="$BACKUP_DIR/$name"
        local src="$f"
        # Scrub secrets from .zshrc before backup
        if [[ "$name" == ".zshrc" ]]; then
            src=$(_scrub_secrets "$f")
        fi
        if [[ -f "$dest" ]] && ! diff -q "$src" "$dest" &>/dev/null; then
            echo -e "  ${Y}~${N} $name (changed)"
            diff --unified=2 "$dest" "$src" 2>/dev/null | head -10 | sed 's/^/      /'
            read -r -p "    Overwrite? [Y/n] " yn
            [[ "$yn" =~ ^[nN] ]] && { [[ "$src" != "$f" ]] && rm -f "$src"; echo "    Skipped."; continue; }
        fi
        cp "$src" "$dest"
        [[ "$src" != "$f" ]] && rm -f "$src"
        echo -e "  ${G}✓${N} $name"
    done
    echo ""
    mkdir -p "$BACKUP_DIR/claude"
    for item in "${CLAUDE_ITEMS[@]}"; do
        [[ -e "$item" ]] || continue
        local name
        name=$(basename "$item")
        if [[ -d "$item" ]]; then
            rsync -a --delete "$item/" "$BACKUP_DIR/claude/$name/" 2>/dev/null
        else
            cp "$item" "$BACKUP_DIR/claude/$name" 2>/dev/null
        fi
        echo -e "  ${G}✓${N} claude/$name"
    done
    if command -v brew &>/dev/null; then
        echo ""
        brew bundle dump --force --file="$TOOLKIT_DIR/Brewfile" 2>/dev/null
        echo -e "  ${G}✓${N} Brewfile exported"
    fi
    date +%s > "$BACKUP_DIR/.last-backup"
    echo -e "\n${G}Backup complete!${N}"
}

do_restore() {
    [[ -d "$BACKUP_DIR" ]] || { ui_fail "No backup found at $BACKUP_DIR"; return 1; }
    local ts
    ts=$(date +%Y%m%d-%H%M%S)
    title_box "Dotfile Restore"
    echo -e "  ${DIM}Restore dotfiles from the backup to your home directory.${NC}"
    echo ""
    ui_warn "Current files will be saved as .bak-$ts"
    echo ""
    for f in "${DOTFILES[@]}"; do
        local name
        name=$(basename "$f")
        local src="$BACKUP_DIR/$name"
        [[ -f "$src" ]] || continue
        if [[ -f "$f" ]]; then
            if diff -q "$f" "$src" &>/dev/null; then
                echo -e "  ${G}✓${N} $name (already matches)"; continue
            fi
            cp "$f" "${f}.bak-${ts}"
        fi
        mkdir -p "$(dirname "$f")"
        cp "$src" "$f"
        echo -e "  ${G}✓${N} $name restored"
    done
    if [[ -d "$BACKUP_DIR/claude" ]]; then
        echo ""
        mkdir -p "$HOME/.claude"
        for item in "$BACKUP_DIR/claude"/*; do
            local name
        name=$(basename "$item")
            if [[ -d "$item" ]]; then
                rsync -a "$item/" "$HOME/.claude/$name/" 2>/dev/null
            else
                cp "$item" "$HOME/.claude/$name" 2>/dev/null
            fi
            echo -e "  ${G}✓${N} claude/$name"
        done
    fi
    if [[ -f "$TOOLKIT_DIR/Brewfile" ]]; then
        echo ""
        read -r -p "Restore brew packages from Brewfile? [y/N] " yn
        [[ "$yn" =~ ^[yY] ]] && brew bundle --file="$TOOLKIT_DIR/Brewfile"
    fi
    echo -e "\n${G}Restore complete!${N}"
}

do_hook() {
    local marker="# toolkit-dotbackup-hook"
    if grep -q "$marker" "$HOME/.zshrc" 2>/dev/null; then
        echo -e "${G}Auto-backup hook already installed.${N}"; return
    fi
    cat >> "$HOME/.zshrc" << HOOK

# toolkit-dotbackup-hook
zshexit() { bash "${TOOLKIT_DIR}/scripts/dotbackup" 2>/dev/null; }
HOOK
    echo -e "${G}✓ Auto-backup hook installed in .zshrc${N}"
    echo -e "${D}Dotfiles will auto-backup when you close a terminal.${N}"
}

case "$ACTION" in
    backup)
        do_backup
        agent_remember "Dotfiles backed up on $(date +%Y-%m-%d)" 2>/dev/null
        ;;
    restore) do_restore ;;
    diff)    show_diff ;;
    hook)    do_hook ;;
    *)       echo "Usage: dotbackup [backup|restore|diff|hook]" ;;
esac
